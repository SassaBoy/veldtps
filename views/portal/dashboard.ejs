<%- include('../partials/header') %>

<style>
  /* ── Portal Navbar ──────────────────────────────────────────────────────── */
  .nm-portal-nav {
    position: sticky;
    top: 0;
    z-index: 1030;
    height: 62px;
    background: #0d1b2a;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3);
  }
  .nm-portal-nav::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #2563eb 30%, #60a5fa 70%, transparent);
    opacity: 0.6;
  }
  .nm-portal-nav .container-fluid {
    height: 100%;
    padding-inline: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nm-portal-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    font-family: 'Sora', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.92);
  }
  .nm-portal-brand-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: linear-gradient(135deg, #2563eb, #60a5fa);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 2px 10px rgba(96,165,250,0.3);
  }
  .nm-portal-brand-icon i { font-size: 0.95rem; color: #fff; }
  .nm-portal-brand-label { line-height: 1; }
  .nm-portal-brand-name { font-size: 0.95rem; font-weight: 700; color: rgba(255,255,255,0.9); display: block; }
  .nm-portal-brand-sub  { font-size: 0.68rem; color: rgba(255,255,255,0.3); font-weight: 400; font-family: 'DM Sans', sans-serif; display: block; margin-top: 1px; }

  .nm-portal-right {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
  }
  .nm-portal-company {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
    padding: 5px 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 7px;
    white-space: nowrap;
  }
  .nm-portal-logout {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.09);
    background: transparent;
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: 0.16s;
  }
  .nm-portal-logout:hover {
    background: rgba(248,113,113,0.08);
    color: #f87171;
    border-color: rgba(248,113,113,0.2);
  }

  /* ── Page Layout ───────────────────────────────────────────────────────── */
  .nm-page-wrapper { flex: 1; padding: 32px 24px 64px; }
  .nm-page-inner   { max-width: 920px; margin: 0 auto; }

  .nm-alert {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 16px; border-radius: 10px;
    font-size: 0.875rem; font-weight: 500; margin-bottom: 24px;
  }
  .nm-alert i { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
  .nm-alert-success { background: rgba(46,204,138,0.08); border: 1px solid rgba(46,204,138,0.2); color: #2ecc8a; }

  /* Welcome */
  .nm-welcome-hero {
    background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 16px;
    padding: 24px 28px; display: flex; align-items: center; gap: 20px; margin-bottom: 28px;
  }
  .nm-welcome-avatar {
    width: 56px; height: 56px; border-radius: 14px; flex-shrink: 0;
    background: linear-gradient(135deg, #1d4ed8, #60a5fa);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Sora', sans-serif; font-size: 1.4rem; font-weight: 700; color: #fff;
  }
  .nm-welcome-name { font-family: 'Sora', sans-serif; font-size: 1.32rem; font-weight: 700; color: rgba(255,255,255,0.92); margin: 0; letter-spacing: -0.02em; }
  .nm-welcome-meta { font-size: 0.855rem; color: rgba(255,255,255,0.38); margin: 5px 0 0; }

  /* Leave Cards */
  .nm-leave-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 32px; }

  .nm-leave-card {
    background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px;
    padding: 20px 22px; transition: all 0.18s;
  }
  .nm-leave-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.35); }

  .nm-leave-header { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; }
  .nm-leave-icon {
    width: 48px; height: 48px; border-radius: 12px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 1.25rem;
  }
  .nm-leave-card.annual .nm-leave-icon { background: rgba(52,211,153,0.12); color: #34d399; }
  .nm-leave-card.sick   .nm-leave-icon { background: rgba(96,165,250,0.12); color: #60a5fa; }

  .nm-leave-title { font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.9); }

  .nm-leave-breakdown { display: flex; flex-direction: column; gap: 8px; font-size: 0.82rem; }
  .nm-leave-row { display: flex; justify-content: space-between; }
  .nm-leave-label { color: rgba(255,255,255,0.45); }
  .nm-leave-paid   { color: #34d399; font-weight: 600; }
  .nm-leave-unpaid { color: #f87171; font-weight: 600; }

  .nm-leave-balance {
    margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.06);
    font-size: 0.78rem; color: rgba(255,255,255,0.35);
  }

  /* Table */
  .nm-section-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: rgba(255,255,255,0.28); margin: 0 0 12px 4px;
  }

  .nm-panel { background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; overflow: hidden; }
  .nm-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px; border-bottom: 1px solid rgba(255,255,255,0.07); background: #112235;
  }
  .nm-panel-title { font-family: 'Sora', sans-serif; font-size: 0.875rem; font-weight: 600; color: rgba(255,255,255,0.85); }

  .nm-table { width: 100%; border-collapse: collapse; font-size: 0.855rem; }
  .nm-table thead th {
    padding: 12px 16px; font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; color: rgba(255,255,255,0.3); background: #112235; text-align: left;
  }
  .nm-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.12s; }
  .nm-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .nm-table td { padding: 14px 16px; vertical-align: middle; }

  .nm-money { font-family: 'Sora', sans-serif; font-weight: 600; white-space: nowrap; font-size: 0.875rem; }
  .nm-net-chip {
    display: inline-flex; align-items: center; gap: 6px; background: rgba(46,204,138,0.1);
    border: 1px solid rgba(46,204,138,0.25); border-radius: 8px; padding: 6px 12px;
    font-family: 'Sora', sans-serif; font-weight: 700; font-size: 0.88rem; color: #2ecc8a;
  }

  .nm-pdf-btn, .nm-paye5-btn {
    display: inline-flex; align-items: center; gap: 6px; padding: 6px 13px; border-radius: 8px;
    font-size: 0.78rem; font-weight: 600; text-decoration: none; transition: 0.16s;
  }
  .nm-pdf-btn {
    border: 1px solid rgba(248,113,113,0.25); background: rgba(248,113,113,0.08); color: #f87171;
  }
  .nm-paye5-btn {
    border: 1px solid rgba(167,139,250,0.3); background: rgba(167,139,250,0.08); color: #a78bfa;
  }

  .nm-empty { text-align: center; padding: 70px 24px; color: rgba(255,255,255,0.3); }
  .nm-empty i { font-size: 2.8rem; opacity: 0.15; margin-bottom: 12px; }

  .nm-disclaimer {
    margin-top: 32px; font-size: 0.8rem; color: rgba(255,255,255,0.4);
    display: flex; gap: 10px;
  }
  .nm-disclaimer i { flex-shrink: 0; margin-top: 2px; }

  /* ── Responsive Fixes ───────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .nm-page-wrapper { padding: 24px 20px 48px; }
    .nm-welcome-hero { padding: 20px; gap: 16px; flex-wrap: wrap; }
    .nm-welcome-avatar { width: 48px; height: 48px; font-size: 1.25rem; }
  }

  @media (max-width: 576px) {
    .nm-page-wrapper { padding: 20px 16px 40px; }
    .nm-leave-grid { grid-template-columns: 1fr; gap: 14px; }
    .nm-leave-card { padding: 18px 20px; }
    .nm-panel-header { flex-direction: column; align-items: flex-start; gap: 8px; }
    .nm-table thead th, .nm-table td { padding: 12px 10px; font-size: 0.82rem; }
  }

  @media (max-width: 480px) {
    .nm-portal-nav .container-fluid { padding-inline: 16px; }
    .nm-portal-company, .nm-portal-logout { font-size: 0.78rem; padding: 6px 10px; }
  }
</style>

<!-- Portal Navbar -->
<nav class="nm-portal-nav navbar navbar-dark">
  <div class="container-fluid">
    <a class="nm-portal-brand" href="/portal/dashboard">
      <span class="nm-portal-brand-icon"><i class="bi bi-person-badge"></i></span>
      <span class="nm-portal-brand-label">
        <span class="nm-portal-brand-name">Employee Portal</span>
        <span class="nm-portal-brand-sub">Veldt Payroll</span>
      </span>
    </a>
    <div class="nm-portal-right">
      <% if (employee.companyName) { %>
        <span class="nm-portal-company">
          <i class="bi bi-building me-1"></i><%= employee.companyName %>
        </span>
      <% } %>
      <form action="/portal/logout" method="POST" class="d-inline">
        <button type="submit" class="nm-portal-logout">
          <i class="bi bi-box-arrow-right"></i> Logout
        </button>
      </form>
    </div>
  </div>
</nav>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <% if (success && success.length > 0) { %>
      <div class="nm-alert nm-alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span><%= success[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Welcome -->
    <div class="nm-welcome-hero">
      <div class="nm-welcome-avatar"><%= (employee.fullName || '?').charAt(0).toUpperCase() %></div>
      <div>
        <h1 class="nm-welcome-name">Welcome back, <%= (employee.fullName || '').split(' ')[0] %>!</h1>
        <p class="nm-welcome-meta">
          <% if (employee.position) { %><%= employee.position %><% } %>
          <% if (employee.department) { %> • <%= employee.department %><% } %>
        </p>
      </div>
    </div>

    <!-- Leave Summary - Updated with refined tracking -->
    <div class="nm-section-label">Your Leave This Year</div>
    <div class="nm-leave-grid">
      <!-- Annual Leave -->
      <div class="nm-leave-card annual">
        <div class="nm-leave-header">
          <div class="nm-leave-icon"><i class="bi bi-calendar-check-fill"></i></div>
          <div class="nm-leave-title">Annual Leave</div>
        </div>
        <div class="nm-leave-breakdown">
          <div class="nm-leave-row">
            <span class="nm-leave-label">Paid</span>
            <span class="nm-leave-paid"><%= employee.annualLeavePaidYTD || 0 %> days</span>
          </div>
          <div class="nm-leave-row">
            <span class="nm-leave-label">Unpaid</span>
            <span class="nm-leave-unpaid"><%= employee.annualLeaveUnpaidYTD || 0 %> days</span>
          </div>
        </div>
        <div class="nm-leave-balance">
          Remaining Balance: <strong><%= employee.annualLeaveBalance || 0 %></strong> days
        </div>
      </div>

      <!-- Sick Leave -->
      <div class="nm-leave-card sick">
        <div class="nm-leave-header">
          <div class="nm-leave-icon"><i class="bi bi-heart-pulse-fill"></i></div>
          <div class="nm-leave-title">Sick Leave</div>
        </div>
        <div class="nm-leave-breakdown">
          <div class="nm-leave-row">
            <span class="nm-leave-label">Paid</span>
            <span class="nm-leave-paid"><%= employee.sickLeavePaidYTD || 0 %> days</span>
          </div>
          <div class="nm-leave-row">
            <span class="nm-leave-label">Unpaid</span>
            <span class="nm-leave-unpaid"><%= employee.sickLeaveUnpaidYTD || 0 %> days</span>
          </div>
        </div>
        <div class="nm-leave-balance">
          Remaining Balance: <strong><%= employee.sickLeaveBalance || 0 %></strong> days
        </div>
      </div>
    </div>

    <!-- Payslip History -->
    <div class="nm-section-label">Payslip History & Tax Documents</div>
    <div class="nm-panel">
      <div class="nm-panel-header">
        <div class="nm-panel-title">
          <i class="bi bi-receipt me-2"></i>My Payslips
        </div>
        <span class="nm-panel-meta"><%= myPayslips.length %> record<%= myPayslips.length !== 1 ? 's' : '' %></span>
      </div>

      <% if (myPayslips.length === 0) { %>
        <div class="nm-empty">
          <i class="bi bi-inbox"></i>
          <h3>No payslips yet</h3>
          <p>Your payslips will appear here once your employer processes payroll.</p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="nm-table">
            <thead>
              <tr>
                <th>Period</th>
                <th>Gross Pay</th>
                <th>PAYE</th>
                <th>SSC</th>
                <th>Net Pay</th>
                <th>Documents</th>
              </tr>
            </thead>
            <tbody>
              <% 
                const taxYears = {};
                myPayslips.forEach(ps => {
                  const ty = ps.month >= 3 ? ps.year : ps.year - 1;
                  if (!taxYears[ty]) taxYears[ty] = [];
                  taxYears[ty].push(ps);
                });

                Object.keys(taxYears).sort((a,b) => b - a).forEach(ty => {
                  const group = taxYears[ty].sort((a,b) => b.year - a.year || b.month - a.month);
              %>
                <tr class="nm-tax-year-row">
                  <td colspan="5">
                    <span class="nm-tax-year-badge">
                      <i class="bi bi-calendar-range"></i> Tax Year <%= ty %>/<%= parseInt(ty)+1 %>
                    </span>
                  </td>
                  <td style="text-align:right;">
                    <a href="/portal/paye5/<%= ty %>" class="nm-paye5-btn">
                      <i class="bi bi-file-earmark-person-fill"></i> ITA5 Certificate
                    </a>
                  </td>
                </tr>

                <% group.forEach(ps => {
                  const periodRef = `PS-${ps.year}${String(ps.month).padStart(2,'0')}`;
                %>
                  <tr>
                    <td>
                      <%= moment(`${ps.year}-${String(ps.month).padStart(2,'0')}-01`).format('MMMM YYYY') %>
                      <span class="nm-period-ref"><%= periodRef %></span>
                    </td>
                    <td><span class="nm-money">N$ <%= Number(ps.grossPay || 0).toLocaleString('en-NA',{minimumFractionDigits:2}) %></span></td>
                    <td><span class="nm-money" style="color:#f87171;">N$ <%= Number(ps.paye || 0).toLocaleString('en-NA',{minimumFractionDigits:2}) %></span></td>
                    <td><span class="nm-money" style="color:#fb923c;">N$ <%= Number(ps.sscEmployee || 0).toLocaleString('en-NA',{minimumFractionDigits:2}) %></span></td>
                    <td><span class="nm-net-chip">N$ <%= Number(ps.netPay || 0).toLocaleString('en-NA',{minimumFractionDigits:2}) %></span></td>
                    <td>
                      <a href="/portal/payslip/<%= ps.runId %>/<%= ps.payslipId %>/pdf" class="nm-pdf-btn">
                        <i class="bi bi-file-earmark-pdf"></i> Payslip
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <!-- Disclaimer -->
    <div class="nm-disclaimer">
      <i class="bi bi-info-circle-fill"></i>
      <div>
        These figures are generated from your employer's payroll records. 
        The <strong>ITA5 Certificate</strong> button downloads your annual income tax certificate for that tax year.
        For any questions about your pay or leave taken, contact your HR or payroll administrator.
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>