<%- include('../partials/header') %>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .nm-auth-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080f1a;
    background-image:
      radial-gradient(ellipse 70% 50% at 20% 55%, rgba(245,166,35,0.05) 0%, transparent 65%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(96,165,250,0.04) 0%, transparent 65%);
    padding: 120px 20px 80px;
  }

  .nm-auth-card {
    width: 100%;
    max-width: 440px;
    background: linear-gradient(145deg, #0d1b2a 0%, #0a1520 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 52px 40px 48px;
    box-shadow:
      0 32px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.03) inset,
      0 1px 0 rgba(255,255,255,0.07) inset;
    position: relative;
    animation: slideUp 0.4s cubic-bezier(0.22,1,0.36,1) both;
  }
  .nm-auth-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,166,35,0.3), transparent);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    -webkit-background-clip: text;
    -webkit-text-fill-color: #ffffff !important;
    transition: background-color 5000s ease-in-out 0s;
    box-shadow: inset 0 0 20px 20px #0e2035 !important;
  }

  /* ── Brand - Consistent with navbar ─────────────────────────────── */
  .nm-auth-brand { text-align: center; margin-bottom: 36px; }
    .nm-auth-brand-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: linear-gradient(135deg, #f5a623, #e8981e);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px; box-shadow: 0 4px 16px rgba(245,166,35,0.25);
  }
  .nm-auth-brand-icon i { font-size: 1.5rem; color: #fff; }
  .nm-auth-title { font-family: 'Sora', sans-serif; font-size: 1.35rem; font-weight: 700; color: rgba(255,255,255,0.92); margin: 0 0 4px; letter-spacing: -0.02em; }
  .nm-auth-sub { font-size: 0.85rem; color: rgba(255,255,255,0.4); margin: 0; }

  .nm-auth-title {
    font-family: 'Sora', 'DM Sans', sans-serif;
    font-size: 1.4rem; 
    font-weight: 700;
    color: rgba(255,255,255,0.95); 
    margin: 0 0 5px;
    letter-spacing: -0.01em;
  }
  .nm-auth-sub { 
    font-size: 0.84rem; 
    color: rgba(255,255,255,0.38); 
    margin: 0; 
  }

  /* ── Alerts ───────────────────────────────────────────────────────────── */
  .nm-alert {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 13px 15px; border-radius: 11px;
    font-size: 0.875rem; margin-bottom: 24px; line-height: 1.5;
  }
  .nm-alert i { flex-shrink: 0; margin-top: 2px; }
  .nm-alert-success { background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.25); color: #22c55e; }
  .nm-alert-danger  { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.28); color: #f87171; }

  /* ── Info box ─────────────────────────────────────────────────────────── */
  .nm-info-box {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px 15px; border-radius: 11px; margin-bottom: 24px;
    background: rgba(96,165,250,0.07); border: 1px solid rgba(96,165,250,0.15);
    font-size: 0.84rem; color: rgba(255,255,255,0.52); line-height: 1.55;
  }
  .nm-info-box i { color: #60a5fa; flex-shrink: 0; margin-top: 2px; }

  /* ── Input ────────────────────────────────────────────────────────────── */
  .nm-input-group { position: relative; margin-bottom: 20px; }
  .nm-input-group .nm-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 1rem; color: rgba(255,255,255,0.32); z-index: 2; pointer-events: none;
  }

  .nm-input {
    display: block; width: 100%; padding: 12px 13px 12px 44px;
    background: #0e2035; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; color: rgba(255,255,255,0.92);
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    outline: none; transition: border-color 0.18s, box-shadow 0.18s;
  }
  .nm-input:focus { border-color: rgba(245,166,35,0.5); box-shadow: 0 0 0 3px rgba(245,166,35,0.09); }
  .nm-input::placeholder { color: rgba(255,255,255,0.2); }

  /* ── Submit ───────────────────────────────────────────────────────────── */
  .nm-btn-submit {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px; border-radius: 10px;
    background: linear-gradient(135deg, #f5a623, #e8981e);
    color: #1a0e00; font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    border: none; cursor: pointer; margin-top: 20px;
    transition: opacity 0.16s, transform 0.12s, box-shadow 0.16s;
    box-shadow: 0 4px 18px rgba(245,166,35,0.25);
  }
  .nm-btn-submit:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 6px 24px rgba(245,166,35,0.35); }
  .nm-btn-submit:active { transform: translateY(0); }

  /* ── Back link ────────────────────────────────────────────────────────── */
  .nm-back-link {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    margin-top: 24px; font-size: 0.83rem;
    color: rgba(255,255,255,0.38); text-decoration: none;
    transition: color 0.15s;
  }
  .nm-back-link:hover { color: #f5a623; }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .nm-auth-bg { padding: 100px 16px 60px; align-items: flex-start; }
    .nm-auth-card { padding: 36px 24px 32px; border-radius: 16px; }
    .nm-auth-title { font-size: 1.25rem; }
  }
  @media (max-width: 360px) {
    .nm-auth-card { padding: 28px 18px 28px; }
  }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <!-- Consistent Logo - Same as navbar -->
    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon">
        <i class="bi bi-coin"></i>
      </div>
      <h1 class="nm-auth-title">
        <span style="color:#f5a623;">Veldt</span>Payroll
      </h1>
      <p class="nm-auth-sub">Forgot Portal Password</p>
    </div>

    <!-- Improved success flash - now reliable like main dashboard -->
    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="nm-alert nm-alert-success">
        <i class="bi bi-check-circle-fill"></i>
        <span><%= success[0] %></span>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="nm-alert nm-alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span><%= error[0] %></span>
      </div>
    <% } %>

    <div class="nm-info-box">
      <i class="bi bi-info-circle-fill"></i>
      <span>Enter the email address associated with your employee portal account and we'll send you a secure reset link.</span>
    </div>

    <form action="/portal/forgot-password" method="POST" id="forgotForm">
      <div class="nm-input-group">
        <i class="bi bi-envelope nm-icon"></i>
        <input type="email" name="email" id="email" class="nm-input"
               placeholder="name@company.com" required autocomplete="email" />
      </div>

      <button type="submit" class="nm-btn-submit" id="submitBtn">
        <i class="bi bi-envelope"></i> Send Reset Link
      </button>
    </form>

    <a href="/portal/login" class="nm-back-link">
      <i class="bi bi-arrow-left"></i> Back to Employee Login
    </a>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('forgotForm');
  const btn  = document.getElementById('submitBtn');

  form.addEventListener('submit', () => {
    btn.innerHTML = `
      <span class="spinner-border spinner-border-sm me-2" role="status"></span>
      Sending reset link...
    `;
    btn.style.pointerEvents = 'none';
    btn.style.opacity = '0.75';
  });
});
</script>

<%- include('../partials/footer') %>