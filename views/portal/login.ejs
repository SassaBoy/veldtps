<%- include('../partials/header') %>

<style>
  .nm-auth-bg {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: #0a1520;
    background-image: radial-gradient(ellipse at 20% 50%, rgba(245,166,35,0.04) 0%, transparent 60%),
                      radial-gradient(ellipse at 80% 20%, rgba(245,166,35,0.04) 0%, transparent 60%);
    padding: 24px 16px;
  }

  .nm-auth-card {
    width: 100%; max-width: 420px;
    background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px; padding: 40px 36px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
  }

  .nm-auth-brand { text-align: center; margin-bottom: 32px; }
  .nm-auth-brand-icon {
    width: 52px; height: 52px; border-radius: 14px;
    background: linear-gradient(135deg, #f5a623, #e8981e);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px; box-shadow: 0 4px 16px rgba(245,166,35,0.25);
  }
  .nm-auth-brand-icon i { font-size: 1.5rem; color: #fff; }
  .nm-auth-title { font-family: 'Sora', sans-serif; font-size: 1.35rem; font-weight: 700; color: rgba(255,255,255,0.92); margin: 0 0 4px; letter-spacing: -0.02em; }
  .nm-auth-sub { font-size: 0.85rem; color: rgba(255,255,255,0.4); margin: 0; }

  /* Alerts */
  .nm-alert { display: flex; align-items: flex-start; gap: 12px; padding: 14px; border-radius: 10px; font-size: 0.85rem; margin-bottom: 20px; line-height: 1.5; }
  .nm-alert i { font-size: 1.1rem; flex-shrink: 0; }
  .nm-alert-success { background: rgba(46,204,138,0.1); border: 1px solid rgba(46,204,138,0.25); color: #2ecc8a; }
  .nm-alert-danger { background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.22); color: #f87171; }
  
  /* Resend Link Button */
  .nm-resend-btn {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 10px; padding: 6px 12px;
    background: rgba(248,113,113,0.15); border: 1px solid rgba(248,113,113,0.3);
    border-radius: 6px; color: #f87171; font-weight: 700; font-size: 0.75rem;
    text-decoration: none; transition: all 0.2s;
  }
  .nm-resend-btn:hover { background: #f87171; color: #fff; }

  .nm-field { margin-bottom: 18px; }
  .nm-label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
  .nm-label { font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.65); letter-spacing: 0.01em; }
  
  .nm-input-group { position: relative; }
  .nm-input {
    display: block; width: 100%; padding: 12px 14px;
    background: #112235; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 9px; color: rgba(255,255,255,0.92);
    font-family: 'DM Sans', sans-serif; font-size: 0.95rem; outline: none;
    transition: border-color 0.16s, box-shadow 0.16s;
  }
  .nm-input::placeholder { color: rgba(255,255,255,0.25); }
  .nm-input:focus { border-color: rgba(245,166,35,0.5); box-shadow: 0 0 0 3px rgba(245,166,35,0.1); }

  /* Autofill Cleanup */
  .nm-input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 1000px #112235 inset !important;
    -webkit-text-fill-color: rgba(255,255,255,0.92) !important;
  }

  .nm-pw-toggle {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: transparent; border: none; color: rgba(255,255,255,0.3);
    cursor: pointer; font-size: 1.1rem; padding: 4px; transition: color 0.2s;
  }
  .nm-pw-toggle:hover { color: #f5a623; }

  .nm-forgot-link { font-size: 0.75rem; color: #f5a623; text-decoration: none; font-weight: 600; }
  .nm-forgot-link:hover { text-decoration: underline; }

  .nm-btn-submit {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 13px; border-radius: 9px;
    background: linear-gradient(135deg, #f5a623, #e8981e); color: #1a0e00;
    font-family: 'DM Sans', sans-serif; font-size: 0.95rem; font-weight: 700;
    border: none; cursor: pointer; margin-top: 10px;
    transition: opacity 0.16s, box-shadow 0.16s, transform 0.1s;
  }
  .nm-btn-submit:hover { opacity: 0.95; box-shadow: 0 8px 24px rgba(245,166,35,0.25); transform: translateY(-1px); }

  .nm-auth-divider { display: flex; align-items: center; gap: 12px; margin: 28px 0; }
  .nm-auth-divider::before, .nm-auth-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.06); }
  .nm-auth-divider span { font-size: 0.7rem; color: rgba(255,255,255,0.25); text-transform: uppercase; letter-spacing: 0.1em; }

  .nm-auth-footer { text-align: center; }
  .nm-auth-footer a { color: #f5a623; font-weight: 600; text-decoration: none; font-size: 0.85rem; transition: 0.2s; }
  .nm-auth-footer a:hover { color: #fff; }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon"><i class="bi bi-coin" ></i></div>
      <h1 class="nm-auth-title">Employee Portal</h1>
      <p class="nm-auth-sub">VeldtPayroll Self-Service Dashboard</p>
    </div>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="nm-alert nm-alert-success fade show">
        <i class="bi bi-check-circle-fill"></i>
        <span><%- success[0] %></span>
      </div>
    <% } %>

    <% if ( (typeof error !== 'undefined' && error.length > 0) || (typeof errors !== 'undefined' && errors.length > 0) ) { %>
      <div class="nm-alert nm-alert-danger fade show">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
          <% if (typeof error !== 'undefined' && error.length > 0) { %>
             <div><%= error[0] %></div>
          <% } %>
          <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <% errors.forEach(e => { %>
              <div><%= e.msg %></div>
              <% if (e.resendEmail) { %>
                <a href="/portal/resend-verification?email=<%= encodeURIComponent(e.resendEmail) %>" class="nm-resend-btn">
                  <i class="bi bi-envelope-paper"></i> Resend Verification Link
                </a>
              <% } %>
            <% }) %>
          <% } %>
        </div>
      </div>
    <% } %>

    <form action="/portal/login" method="POST" novalidate>
      <div class="nm-field">
        <label class="nm-label">Email Address</label>
        <input type="email" name="email" class="nm-input"
               placeholder="name@company.com"
               value="<%= typeof formData !== 'undefined' ? formData.email || '' : '' %>" required />
      </div>

      <div class="nm-field" style="margin-bottom:28px">
        <div class="nm-label-row">
          <label class="nm-label">Password</label>
          <a href="/portal/forgot-password" class="nm-forgot-link">Forgot Password?</a>
        </div>
        <div class="nm-input-group">
          <input type="password" name="password" id="password" class="nm-input"
                 placeholder="••••••••" required />
          <button type="button" class="nm-pw-toggle" id="togglePassword">
            <i class="bi bi-eye-slash" id="eyeIcon"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="nm-btn-submit">
        <i class="bi bi-box-arrow-in-right"></i> Sign In to Portal
      </button>
    </form>

    <div class="nm-auth-divider"><span>System Access</span></div>

    <div class="nm-auth-footer">
      <p><a href="/login"><i class="bi bi-arrow-left me-2"></i>Back to Company Admin</a></p>
    </div>

  </div>
</div>

<script>
  const togglePassword = document.querySelector('#togglePassword');
  const passwordInput = document.querySelector('#password');
  const eyeIcon = document.querySelector('#eyeIcon');

  togglePassword.addEventListener('click', function() {
    const isPassword = passwordInput.getAttribute('type') === 'password';
    passwordInput.setAttribute('type', isPassword ? 'text' : 'password');
    eyeIcon.classList.toggle('bi-eye');
    eyeIcon.classList.toggle('bi-eye-slash');
  });
</script>

<%- include('../partials/footer') %>