<%- include('../partials/header') %>

<style>
  .nm-auth-bg {
    min-height:100vh; display:flex; align-items:center; justify-content:center;
    background:#0a1520;
    background-image: radial-gradient(ellipse at 20% 50%, rgba(245,166,35,0.04) 0%, transparent 60%),
                      radial-gradient(ellipse at 80% 20%, rgba(245,166,35,0.04) 0%, transparent 60%);
    padding:24px 16px;
  }

  .nm-auth-card {
    width:100%; max-width:420px;
    background:#0d1b2a; border:1px solid rgba(255,255,255,0.07);
    border-radius:18px; padding:40px 36px;
    box-shadow:0 24px 64px rgba(0,0,0,0.5);
  }

  .nm-auth-brand { text-align:center; margin-bottom:32px; }
  .nm-auth-brand-icon {
    width:52px; height:52px; border-radius:14px;
    background:linear-gradient(135deg,#f5a623,#e8981e);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 14px; box-shadow:0 4px 16px rgba(245,166,35,0.25);
  }
  .nm-auth-brand-icon i { font-size:1.5rem; color:#1a0e00; }
  .nm-auth-title { font-family:'Sora',sans-serif; font-size:1.35rem; font-weight:700; color:rgba(255,255,255,0.92); margin:0 0 4px; letter-spacing:-0.02em; }
  .nm-auth-sub   { font-size:0.85rem; color:rgba(255,255,255,0.4); margin:0; }

  .nm-alert { display:flex; align-items:flex-start; gap:10px; padding:11px 14px; border-radius:9px; font-size:0.845rem; font-weight:500; margin-bottom:18px; }

  .nm-field { margin-bottom:18px; position:relative; }
  .nm-label { font-size:0.82rem; font-weight:600; color:rgba(255,255,255,0.65); }
  .nm-input {
    display:block; width:100%; padding:11px 14px;
    background:#112235; border:1px solid rgba(255,255,255,0.07);
    border-radius:9px; color:rgba(255,255,255,0.92);
    font-family:'DM Sans',sans-serif; font-size:0.9rem;
    outline:none;
  }
  .nm-input:focus { border-color:rgba(245,166,35,0.5); box-shadow:0 0 0 3px rgba(245,166,35,0.1); }

  .nm-pw-toggle {
    position:absolute; right:12px; top:50%; transform:translateY(-50%);
    background:transparent; border:none; padding:4px;
    color:rgba(255,255,255,0.3); cursor:pointer; font-size:1.1rem;
  }

  .nm-validation-msg { font-size:0.78rem; margin-top:4px; display:block; }
  .nm-validation-success { color:#22c55e; }
  .nm-validation-error   { color:#f87171; }

  .nm-btn-submit {
    display:flex; align-items:center; justify-content:center; gap:8px;
    width:100%; padding:12px; border-radius:9px;
    background:linear-gradient(135deg,#f5a623,#e8981e); color:#1a0e00;
    font-family:'DM Sans',sans-serif; font-size:0.925rem; font-weight:700;
    border:none; cursor:pointer; margin-top:10px;
    transition:opacity 0.16s;
  }
  .nm-btn-submit:hover { opacity:0.92; }
  .nm-btn-submit:disabled { opacity:0.75; cursor:not-allowed; }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon"><i class="bi bi-person-badge"></i></div>
      <h1 class="nm-auth-title">New Portal Password</h1>
      <p class="nm-auth-sub">Set a new secure password</p>
    </div>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="nm-alert nm-alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i><span><%= success[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="nm-alert nm-alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i><span><%= error[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="nm-alert nm-alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill"></i>
        <div><% errors.forEach(e => { %><div>• <%= e.msg %></div><% }) %></div>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <form action="/portal/reset-password/<%= token %>" method="POST" id="resetForm">
      <div class="nm-field">
        <label class="nm-label">New Password</label>
        <div style="position:relative;">
          <input type="password" name="password" id="password" class="nm-input" placeholder="••••••••" required />
          <button type="button" class="nm-pw-toggle" id="togglePassword">
            <i class="bi bi-eye-slash" id="eyeIcon1"></i>
          </button>
        </div>
        <small id="passwordMsg" class="nm-validation-msg"></small>
      </div>

      <div class="nm-field">
        <label class="nm-label">Confirm Password</label>
        <div style="position:relative;">
          <input type="password" name="confirmPassword" id="confirmPassword" class="nm-input" placeholder="••••••••" required />
          <button type="button" class="nm-pw-toggle" id="toggleConfirm">
            <i class="bi bi-eye-slash" id="eyeIcon2"></i>
          </button>
        </div>
        <small id="confirmMsg" class="nm-validation-msg"></small>
      </div>

      <button type="submit" id="submitBtn" class="nm-btn-submit">
        <i class="bi bi-shield-check"></i> Update Password
      </button>
    </form>

  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const pw = document.getElementById('password');
  const cpw = document.getElementById('confirmPassword');
  const pwMsg = document.getElementById('passwordMsg');
  const cpwMsg = document.getElementById('confirmMsg');
  const form = document.getElementById('resetForm');
  const btn = document.getElementById('submitBtn');

  // Eye toggles
  [{btn: 'togglePassword', icon: 'eyeIcon1', input: pw},
   {btn: 'toggleConfirm',  icon: 'eyeIcon2', input: cpw}]
    .forEach(({btn, icon, input}) => {
      document.getElementById(btn).addEventListener('click', function() {
        const isPass = input.type === 'password';
        input.type = isPass ? 'text' : 'password';
        const i = document.getElementById(icon);
        i.classList.toggle('bi-eye');
        i.classList.toggle('bi-eye-slash');
      });
    });

  // Live validation
  const validate = () => {
    if (pw.value.length > 0) {
      const strong = pw.value.length >= 8;
      pwMsg.textContent = strong ? '✓ Strength: Good' : 'Minimum 8 characters';
      pwMsg.className = 'nm-validation-msg ' + (strong ? 'nm-validation-success' : 'nm-validation-error');
    }
    if (cpw.value.length > 0) {
      const match = pw.value === cpw.value;
      cpwMsg.textContent = match ? '✓ Passwords match' : 'Passwords do not match';
      cpwMsg.className = 'nm-validation-msg ' + (match ? 'nm-validation-success' : 'nm-validation-error');
    }
  };

  pw.addEventListener('input', validate);
  cpw.addEventListener('input', validate);

  // Loading state
  form.addEventListener('submit', () => {
    btn.disabled = true;
    btn.innerHTML = `
      <span class="spinner-border spinner-border-sm me-2" role="status"></span>
      Updating password...
    `;
  });
});
</script>

<%- include('../partials/footer') %>