<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'NamPayroll' %></title>

  <!-- Bootstrap 5 -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&display=swap" rel="stylesheet" />
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css" />

  <style>
    /* ── Design tokens ─────────────────────────────────────────── */
    :root {
      --nm-navy:         #0d1b2a;
      --nm-navy-mid:     #112235;
      --nm-navy-light:   #1a2f45;
      --nm-border:       rgba(255,255,255,0.07);
      --nm-border-soft:  rgba(255,255,255,0.04);
      --nm-text:         rgba(255,255,255,0.92);
      --nm-text-dim:     rgba(255,255,255,0.65);
      --nm-text-muted:   rgba(255,255,255,0.40);
      --nm-accent:       #f5a623;
      --nm-accent-dim:   rgba(245,166,35,0.10);
      --nm-accent-glow:  rgba(245,166,35,0.22);
      --nm-green:        #2ecc8a;
      --nm-danger:       #f87171;
      --nm-nav-h:        62px;
      --nm-radius:       10px;
    }

    /* ── Base ──────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; }

    html, body {
      height: 100%;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #0a1520;
      color: var(--nm-text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── NAVBAR ────────────────────────────────────────────────── */
    .nm-navbar {
      position: sticky;
      top: 0;
      z-index: 1030;
      height: var(--nm-nav-h);
      background: var(--nm-navy);
      border-bottom: 1px solid var(--nm-border);
      box-shadow: 0 4px 24px rgba(0,0,0,0.30);
    }

    /* Gold top stripe */
    .nm-navbar::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--nm-accent) 30%, var(--nm-accent) 70%, transparent);
      opacity: 0.55;
    }

    .nm-navbar-inner {
      height: 100%;
      padding-inline: 24px;
    }

    /* Brand */
    .nm-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      margin-right: 8px;
      transition: opacity 0.2s;
    }
    .nm-brand:hover { opacity: 0.82; }

    .nm-brand-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--nm-accent), #d4880a);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 10px var(--nm-accent-glow);
      flex-shrink: 0;
    }
    .nm-brand-icon i { font-size: 0.95rem; color: #fff; }

    .nm-brand-text {
      font-family: 'Sora', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--nm-text);
    }
    .nm-brand-highlight { color: var(--nm-accent); }

    /* Divider */
    .nm-nav-divider {
      width: 1px;
      height: 26px;
      background: var(--nm-border);
      margin: 0 24px 0 16px;
      flex-shrink: 0;
    }

    /* Nav links */
    .nm-nav-link {
      display: flex !important;
      align-items: center;
      gap: 7px;
      font-size: 0.865rem;
      font-weight: 500;
      color: var(--nm-text-dim) !important;
      padding: 6px 13px !important;
      border-radius: 8px;
      letter-spacing: 0.01em;
      transition: color 0.16s, background 0.16s;
      position: relative;
    }
    .nm-nav-link i { font-size: 0.92rem; opacity: 0.7; transition: opacity 0.16s; }
    .nm-nav-link:hover { color: var(--nm-text) !important; background: var(--nm-border-soft); }
    .nm-nav-link:hover i { opacity: 1; }

    .nm-nav-link.active {
      color: var(--nm-text) !important;
      background: var(--nm-accent-dim);
    }
    .nm-nav-link.active i { opacity: 1; color: var(--nm-accent); }
    .nm-nav-link.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 50%;
      transform: translateX(-50%);
      width: 18px;
      height: 2px;
      border-radius: 2px;
      background: var(--nm-accent);
    }

    /* Right user area */
    .nm-user-area {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-left: auto;
    }

    /* Icon button */
    .nm-icon-btn {
      width: 34px;
      height: 34px;
      border-radius: 8px;
      border: 1px solid var(--nm-border);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--nm-text-dim);
      font-size: 0.95rem;
      text-decoration: none;
      transition: background 0.16s, border-color 0.16s, color 0.16s;
    }
    .nm-icon-btn:hover {
      background: var(--nm-border-soft);
      border-color: rgba(255,255,255,0.13);
      color: var(--nm-text);
    }

    /* Company trigger */
    .nm-company-trigger {
      display: flex;
      align-items: center;
      gap: 9px;
      padding: 5px 10px 5px 5px;
      border-radius: 10px;
      border: 1px solid var(--nm-border);
      background: var(--nm-navy-light);
      text-decoration: none;
      color: var(--nm-text) !important;
      transition: background 0.16s, border-color 0.16s;
      cursor: pointer;
    }
    .nm-company-trigger::after { display: none; }
    .nm-company-trigger:hover {
      background: rgba(255,255,255,0.06);
      border-color: rgba(255,255,255,0.13);
    }

    .nm-avatar {
      width: 28px;
      height: 28px;
      border-radius: 7px;
      background: linear-gradient(135deg, #2563eb, #60a5fa);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Sora', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .nm-company-info { line-height: 1; }
    .nm-company-name {
      display: block;
      font-size: 0.83rem;
      font-weight: 600;
      max-width: 150px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .nm-company-sub {
      display: block;
      font-size: 0.7rem;
      color: var(--nm-text-muted);
      max-width: 150px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-top: 2px;
    }

    .nm-chevron {
      font-size: 0.72rem;
      color: var(--nm-text-muted);
      transition: transform 0.2s;
      margin-left: 2px;
    }
    .nm-company-trigger[aria-expanded="true"] .nm-chevron { transform: rotate(180deg); }

    /* Dropdown */
    .nm-dropdown {
      min-width: 232px;
      background: var(--nm-navy-mid);
      border: 1px solid var(--nm-border);
      border-radius: var(--nm-radius);
      box-shadow: 0 16px 48px rgba(0,0,0,0.55);
      padding: 6px;
      margin-top: 6px !important;
    }

    .nm-dropdown-header {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 10px 10px 12px;
    }

    .nm-dh-avatar {
      width: 36px;
      height: 36px;
      border-radius: 9px;
      background: linear-gradient(135deg, #2563eb, #60a5fa);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Sora', sans-serif;
      font-size: 0.85rem;
      font-weight: 700;
      color: #fff;
      flex-shrink: 0;
    }

    .nm-dh-company {
      font-size: 0.855rem;
      font-weight: 600;
      color: var(--nm-text);
      line-height: 1.2;
    }
    .nm-dh-email {
      font-size: 0.75rem;
      color: var(--nm-text-muted);
      margin-top: 2px;
    }

    .nm-status-pill {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 0.68rem;
      font-weight: 600;
      color: var(--nm-green);
      background: rgba(46,204,138,0.1);
      border: 1px solid rgba(46,204,138,0.2);
      border-radius: 20px;
      padding: 2px 8px;
      margin-top: 6px;
    }
    .nm-status-dot {
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--nm-green);
      box-shadow: 0 0 4px var(--nm-green);
    }

    .nm-dropdown-sep {
      height: 1px;
      background: var(--nm-border);
      margin: 4px 0;
    }

    .nm-dd-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 10px;
      border-radius: 7px;
      font-size: 0.845rem;
      font-weight: 500;
      color: var(--nm-text-dim);
      text-decoration: none;
      background: transparent;
      border: none;
      width: 100%;
      text-align: left;
      cursor: pointer;
      transition: background 0.14s, color 0.14s;
    }
    .nm-dd-item i { font-size: 0.9rem; opacity: 0.6; }
    .nm-dd-item:hover { background: rgba(255,255,255,0.05); color: var(--nm-text); }
    .nm-dd-item:hover i { opacity: 1; }

    .nm-dd-danger { color: var(--nm-danger) !important; }
    .nm-dd-danger i { color: var(--nm-danger); opacity: 1 !important; }
    .nm-dd-danger:hover { background: rgba(248,113,113,0.08) !important; }

    /* Mobile toggler */
    .nm-toggler {
      border: 1px solid var(--nm-border);
      border-radius: 8px;
      padding: 5px 9px;
      background: transparent;
    }
    .nm-toggler:focus { box-shadow: none; }

    /* Mobile collapse */
    @media (max-width: 991.98px) {
      .nm-navbar-inner { padding-inline: 16px; }

      #mainNav {
        background: var(--nm-navy-mid);
        border-top: 1px solid var(--nm-border);
        border-radius: 0 0 12px 12px;
        padding: 12px 12px 16px;
        box-shadow: 0 12px 32px rgba(0,0,0,0.4);
      }

      .nm-nav-link { padding: 11px 14px !important; font-size: 0.9rem; }
      .nm-nav-link.active::after { display: none; }

      .nm-user-area {
        margin-left: 0;
        padding-top: 12px;
        border-top: 1px solid var(--nm-border);
        width: 100%;
      }

      .nm-company-trigger { width: 100%; }
      .nm-company-info { display: block !important; }
      .nm-company-name { max-width: 100%; }
      .nm-company-sub  { max-width: 100%; }
      .nm-chevron { display: block !important; margin-left: auto; }
    }

    /* ── FOOTER ────────────────────────────────────────────────── */
    .nm-footer {
      background: var(--nm-navy);
      border-top: 1px solid var(--nm-border);
    }

    .nm-footer-inner {
      max-width: 1400px;
      margin: 0 auto;
      padding: 18px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }

    .nm-footer-left {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .nm-footer-brand {
      display: flex;
      align-items: center;
      gap: 7px;
      text-decoration: none;
    }
    .nm-footer-brand-icon {
      width: 22px; height: 22px;
      border-radius: 5px;
      background: linear-gradient(135deg, var(--nm-accent), #d4880a);
      display: flex; align-items: center; justify-content: center;
    }
    .nm-footer-brand-icon i { font-size: 0.65rem; color: #fff; }
    .nm-footer-brand-text {
      font-family: 'Sora', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--nm-text-dim);
    }

    .nm-footer-copy {
      font-size: 0.76rem;
      color: var(--nm-text-muted);
      padding-left: 16px;
      border-left: 1px solid var(--nm-border);
    }

    .nm-footer-links {
      display: flex;
      align-items: center;
      gap: 2px;
    }
    .nm-footer-link {
      font-size: 0.76rem;
      color: var(--nm-text-muted);
      text-decoration: none;
      padding: 3px 9px;
      border-radius: 5px;
      transition: color 0.14s, background 0.14s;
    }
    .nm-footer-link:hover { color: var(--nm-text-dim); background: var(--nm-border-soft); }

    .nm-footer-notice {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      background: rgba(245,166,35,0.06);
      border: 1px solid rgba(245,166,35,0.16);
      border-radius: 8px;
      padding: 8px 14px;
      max-width: 360px;
    }
    .nm-footer-notice i { color: var(--nm-accent); font-size: 0.82rem; margin-top: 1px; flex-shrink: 0; }
    .nm-footer-notice span { font-size: 0.735rem; color: rgba(245,166,35,0.80); line-height: 1.5; }

    @media (max-width: 767.98px) {
      .nm-footer-inner { flex-direction: column; align-items: flex-start; gap: 12px; padding: 16px; }
      .nm-footer-links { display: none; }
      .nm-footer-notice { max-width: 100%; }
      .nm-footer-copy { border-left: none; padding-left: 0; }
    }
  </style>
</head>
<body>
