<%- include('../partials/header') %>

<style>
  .nm-auth-bg {
    min-height:100vh; display:flex; align-items:center; justify-content:center;
    background:#0a1520;
    background-image: radial-gradient(ellipse at 20% 50%, rgba(245,166,35,0.04) 0%, transparent 60%),
                      radial-gradient(ellipse at 80% 20%, rgba(96,165,250,0.04) 0%, transparent 60%);
    padding:32px 16px;
  }

  .nm-auth-card {
    width:100%; max-width:620px;
    background:#0d1b2a; border:1px solid rgba(255,255,255,0.07);
    border-radius:18px; padding:40px 36px;
    box-shadow:0 24px 64px rgba(0,0,0,0.5);
  }

  .nm-auth-brand { text-align:center; margin-bottom:32px; }
  .nm-auth-brand-icon {
    width:52px; height:52px; border-radius:14px;
    background:linear-gradient(135deg,#f5a623,#d4880a);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 14px; box-shadow:0 4px 16px rgba(245,166,35,0.3);
  }
  .nm-auth-brand-icon i { font-size:1.5rem; color:#fff; }
  .nm-auth-title { font-family:'Sora',sans-serif; font-size:1.4rem; font-weight:700; color:rgba(255,255,255,0.92); margin:0 0 4px; letter-spacing:-0.02em; }
  .nm-auth-sub   { font-size:0.85rem; color:rgba(255,255,255,0.4); margin:0; }

  .nm-alert { display:flex; align-items:flex-start; gap:10px; padding:11px 14px; border-radius:9px; font-size:0.845rem; font-weight:500; margin-bottom:20px; }
  .nm-alert i { font-size:0.95rem; flex-shrink:0; margin-top:1px; }
  .nm-alert-danger { background:rgba(248,113,113,0.08); border:1px solid rgba(248,113,113,0.22); color:#f87171; }
  .nm-alert-info   { background:rgba(96,165,250,0.08);  border:1px solid rgba(96,165,250,0.2);  color:#60a5fa; font-size:0.815rem; }

  .nm-field { margin-bottom:18px; }
  .nm-label { display:block; font-size:0.82rem; font-weight:600; color:rgba(255,255,255,0.65); margin-bottom:7px; letter-spacing:0.01em; }
  .nm-required { color:#f5a623; }
  .nm-input {
    display:block; width:100%; padding:10px 13px;
    background:#112235; border:1px solid rgba(255,255,255,0.07);
    border-radius:9px; color:rgba(255,255,255,0.92);
    font-family:'DM Sans',sans-serif; font-size:0.875rem;
    outline:none; transition:border-color 0.16s,box-shadow 0.16s; -webkit-appearance:none;
  }
  .nm-input::placeholder { color:rgba(255,255,255,0.3); }
  .nm-input:focus { border-color:rgba(245,166,35,0.45); box-shadow:0 0 0 3px rgba(245,166,35,0.08); }

  /* Section divider */
  .nm-section-label { font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:rgba(255,255,255,0.25); margin:4px 0 16px; padding-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.06); }

  .nm-btn-submit {
    display:flex; align-items:center; justify-content:center; gap:8px;
    width:100%; padding:12px; border-radius:9px;
    background:#f5a623; color:#1a0e00;
    font-family:'DM Sans',sans-serif; font-size:0.925rem; font-weight:700;
    border:none; cursor:pointer; margin-top:6px;
    transition:background 0.16s,box-shadow 0.16s,transform 0.1s;
  }
  .nm-btn-submit:hover { background:#e8981e; box-shadow:0 4px 18px rgba(245,166,35,0.3); transform:translateY(-1px); }
  .nm-btn-submit:active { transform:translateY(0); }

  .nm-auth-divider { display:flex; align-items:center; gap:12px; margin:24px 0; }
  .nm-auth-divider::before,
  .nm-auth-divider::after { content:''; flex:1; height:1px; background:rgba(255,255,255,0.07); }
  .nm-auth-divider span { font-size:0.75rem; color:rgba(255,255,255,0.3); white-space:nowrap; }

  .nm-auth-footer { text-align:center; }
  .nm-auth-footer p { font-size:0.83rem; color:rgba(255,255,255,0.4); margin:0; }
  .nm-auth-footer a { color:#f5a623; font-weight:600; text-decoration:none; }
  .nm-auth-footer a:hover { text-decoration:underline; }

  @media (max-width:575.98px) {
    .nm-auth-card { padding:28px 20px; }
  }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon"><i class="bi bi-coin"></i></div>
      <h1 class="nm-auth-title">Create Company Account</h1>
      <p class="nm-auth-sub">Set up your NamPayroll account in minutes</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="nm-alert nm-alert-danger">
        <i class="bi bi-exclamation-circle-fill"></i>
        <div><% errors.forEach(e => { %><div><%= e.msg %></div><% }) %></div>
      </div>
    <% } %>

    <form action="/register" method="POST" novalidate>

      <div class="nm-section-label">Company Information</div>
      <div class="row g-3">
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Company Name <span class="nm-required">*</span></label>
            <input type="text" name="companyName" class="nm-input"
                   placeholder="e.g. Sunrise Guesthouse (Pty) Ltd"
                   value="<%= formData.companyName || '' %>" required />
          </div>
        </div>
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Owner / Admin Name <span class="nm-required">*</span></label>
            <input type="text" name="ownerName" class="nm-input"
                   placeholder="e.g. Maria Nakamhela"
                   value="<%= formData.ownerName || '' %>" required />
          </div>
        </div>
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Email Address <span class="nm-required">*</span></label>
            <input type="email" name="email" class="nm-input"
                   placeholder="admin@company.com"
                   value="<%= formData.email || '' %>" required />
          </div>
        </div>
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Phone Number <span class="nm-required">*</span></label>
            <input type="tel" name="phone" class="nm-input"
                   placeholder="+264 81 000 0000"
                   value="<%= formData.phone || '' %>" required />
          </div>
        </div>
      </div>

      <div class="nm-section-label" style="margin-top:8px">Security</div>
      <div class="row g-3">
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Password <span class="nm-required">*</span></label>
            <input type="password" name="password" class="nm-input"
                   placeholder="At least 8 characters" required />
          </div>
        </div>
        <div class="col-md-6">
          <div class="nm-field">
            <label class="nm-label">Confirm Password <span class="nm-required">*</span></label>
            <input type="password" name="confirmPassword" class="nm-input"
                   placeholder="Repeat password" required />
          </div>
        </div>
      </div>

      <div class="nm-alert nm-alert-info">
        <i class="bi bi-shield-check"></i>
        <span>By registering, you agree that all payroll calculations are for guidance only. Always verify with NamRA and Social Security before final submission.</span>
      </div>

      <button type="submit" class="nm-btn-submit">
        <i class="bi bi-building-add"></i>Create Account
      </button>

    </form>

    <div class="nm-auth-divider"><span>or</span></div>

    <div class="nm-auth-footer">
      <p>Already have an account? <a href="/login">Login here</a></p>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
