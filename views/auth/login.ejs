<%- include('../partials/header') %>

<style>
  /* ── Reset & Base ─────────────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  /* ── Layout ───────────────────────────────────────────────────────────── */
  .nm-auth-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080f1a;
    background-image:
      radial-gradient(ellipse 70% 50% at 15% 55%, rgba(245,166,35,0.06) 0%, transparent 65%),
      radial-gradient(ellipse 60% 40% at 85% 20%, rgba(96,165,250,0.05) 0%, transparent 65%),
      radial-gradient(ellipse 40% 30% at 50% 90%, rgba(167,139,250,0.03) 0%, transparent 60%);
    padding: 120px 20px 80px;
  }

  /* ── Card ─────────────────────────────────────────────────────────────── */
  .nm-auth-card {
    width: 100%;
    max-width: 440px;
    background: linear-gradient(145deg, #0d1b2a 0%, #0a1520 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 48px 40px 44px;
    box-shadow:
      0 32px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.04) inset,
      0 1px 0 rgba(255,255,255,0.08) inset;
    position: relative;
    overflow: hidden;
    animation: slideUp 0.4s cubic-bezier(0.22,1,0.36,1) both;
  }
  .nm-auth-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,166,35,0.35), transparent);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Autofill ─────────────────────────────────────────────────────────── */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    -webkit-background-clip: text;
    -webkit-text-fill-color: #ffffff !important;
    transition: background-color 5000s ease-in-out 0s;
    box-shadow: inset 0 0 20px 20px #0e2035 !important;
  }

  /* ── Brand ────────────────────────────────────────────────────────────── */
  .nm-auth-brand { text-align: center; margin-bottom: 36px; }
  .nm-auth-brand-icon {
    width: 56px; height: 56px; border-radius: 16px;
    background: linear-gradient(135deg, #f5a623, #d4880a);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 6px 24px rgba(245,166,35,0.35), 0 0 0 1px rgba(245,166,35,0.2);
  }
  .nm-auth-brand-icon i { font-size: 1.6rem; color: #fff; }
  .nm-auth-title {
    font-family: 'Sora', 'DM Sans', sans-serif;
    font-size: 1.45rem; font-weight: 700;
    color: rgba(255,255,255,0.95); margin: 0 0 5px;
    letter-spacing: -0.01em;
  }
  .nm-auth-sub { font-size: 0.84rem; color: rgba(255,255,255,0.38); margin: 0; }

  /* ── Alerts ───────────────────────────────────────────────────────────── */
  .nm-alert {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 13px 15px; border-radius: 11px;
    font-size: 0.875rem; margin-bottom: 24px; line-height: 1.5;
  }
  .nm-alert i { flex-shrink: 0; margin-top: 2px; }
  .nm-alert-success { background: rgba(46,204,138,0.1); border: 1px solid rgba(46,204,138,0.22); color: #2ecc8a; }
  .nm-alert-danger  { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.28); color: #f87171; }

  .nm-verification-link { color: #f5a623; font-weight: 600; text-decoration: underline; }
  .nm-verification-link:hover { color: #fff; }

  /* ── Fields ───────────────────────────────────────────────────────────── */
  .nm-field { margin-bottom: 18px; }
  .nm-label-wrapper { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; }
  .nm-label { font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.6); margin: 0; }
  .nm-forgot-link { font-size: 0.78rem; color: #f5a623; text-decoration: none; transition: color 0.15s; }
  .nm-forgot-link:hover { color: #fff; }

  /* ── Inputs ───────────────────────────────────────────────────────────── */
  .nm-input-group { position: relative; }
  .nm-input-group .nm-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 1rem; color: rgba(255,255,255,0.35); z-index: 2; pointer-events: none;
  }
  .nm-input {
    display: block; width: 100%; padding: 11px 13px;
    background: #0e2035; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; color: rgba(255,255,255,0.92);
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    outline: none; transition: border-color 0.18s, box-shadow 0.18s;
  }
  .nm-input-group .nm-input { padding-left: 44px; }
  .nm-input:focus {
    border-color: rgba(245,166,35,0.5);
    box-shadow: 0 0 0 3px rgba(245,166,35,0.1);
  }
  .nm-input::placeholder { color: rgba(255,255,255,0.2); }

  .nm-eye {
    position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
    font-size: 1.1rem; color: rgba(255,255,255,0.4);
    cursor: pointer; z-index: 3; transition: color 0.15s;
  }
  .nm-eye:hover { color: rgba(255,255,255,0.7); }

  /* ── Submit ───────────────────────────────────────────────────────────── */
  .nm-btn-submit {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px;
    border-radius: 10px;
    background: linear-gradient(135deg, #f5a623, #e8981e);
    color: #1a0e00; font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    border: none; cursor: pointer; margin-top: 26px;
    transition: opacity 0.16s, transform 0.12s, box-shadow 0.16s;
    box-shadow: 0 4px 18px rgba(245,166,35,0.25);
  }
  .nm-btn-submit:hover {
    opacity: 0.92; transform: translateY(-1px);
    box-shadow: 0 6px 24px rgba(245,166,35,0.35);
  }
  .nm-btn-submit:active { transform: translateY(0); }

  /* ── Divider ──────────────────────────────────────────────────────────── */
  .nm-auth-divider {
    display: flex; align-items: center; gap: 12px; margin: 28px 0;
  }
  .nm-auth-divider::before,
  .nm-auth-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.07); }
  .nm-auth-divider span { font-size: 0.72rem; color: rgba(255,255,255,0.28); }

  /* ── Footer ───────────────────────────────────────────────────────────── */
  .nm-auth-footer { text-align: center; font-size: 0.83rem; color: rgba(255,255,255,0.38); }
  .nm-auth-footer a { color: #f5a623; font-weight: 600; text-decoration: none; transition: color 0.15s; }
  .nm-auth-footer a:hover { color: #fff; text-decoration: underline; }
  .nm-portal-link {
    display: inline-flex; align-items: center; gap: 6px;
    margin-top: 12px; color: rgba(255,255,255,0.3) !important;
    font-weight: 400 !important; font-size: 0.8rem;
    transition: color 0.15s !important;
  }
  .nm-portal-link:hover { color: rgba(255,255,255,0.6) !important; text-decoration: none !important; }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .nm-auth-bg { padding: 100px 16px 60px; align-items: flex-start; }
    .nm-auth-card { padding: 36px 24px 32px; border-radius: 16px; }
    .nm-auth-title { font-size: 1.25rem; }
    .nm-btn-submit { padding: 13px; font-size: 0.92rem; }
  }
  @media (max-width: 360px) {
    .nm-auth-card { padding: 28px 18px 28px; }
  }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon"><i class="bi bi-coin"></i></div>
      <h1 class="nm-auth-title">Welcome Back</h1>
      <p class="nm-auth-sub">Log in to manage your company payroll</p>
    </div>

    <% if (typeof success !== 'undefined' && success.length > 0) { %>
      <div class="nm-alert nm-alert-success">
        <i class="bi bi-check-circle-fill"></i><span><%= success[0] %></span>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error.length > 0) { %>
      <div class="nm-alert nm-alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i><span><%= error[0] %></span>
      </div>
    <% } %>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
      <div class="nm-alert nm-alert-danger">
        <i class="bi bi-exclamation-circle-fill"></i>
        <div>
          <% errors.forEach(e => { %>
            <div>
              <%= e.msg %>
              <% if (e.resendEmail) { %>
                <br>
                <a href="/resend-verification?email=<%= encodeURIComponent(e.resendEmail) %>" class="nm-verification-link">
                  Click here to resend verification email
                </a>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <form action="/login" method="POST" autocomplete="on">
      <div class="nm-field">
        <label class="nm-label">Email Address</label>
        <div class="nm-input-group">
          <i class="bi bi-envelope nm-icon"></i>
          <input type="email" name="email" class="nm-input"
            placeholder="admin@company.com"
            value="<%= formData?.email || '' %>" required autocomplete="email" />
        </div>
      </div>

      <div class="nm-field" style="margin-bottom:0;">
        <div class="nm-label-wrapper">
          <label class="nm-label">Password</label>
          <a href="/forgot-password" class="nm-forgot-link">Forgot Password?</a>
        </div>
        <div class="nm-input-group">
          <i class="bi bi-lock nm-icon"></i>
          <input type="password" name="password" id="password" class="nm-input"
            placeholder="••••••••" required autocomplete="current-password" />
          <i class="bi bi-eye-slash nm-eye" id="togglePassword" role="button" aria-label="Toggle password visibility"></i>
        </div>
      </div>

      <button type="submit" class="nm-btn-submit">
        <i class="bi bi-box-arrow-in-right"></i> Sign In
      </button>
    </form>

    <div class="nm-auth-divider"><span>or</span></div>

    <div class="nm-auth-footer" >
      <p>Need an account? <a href="/register">Register your company</a></p>
      <a href="/portal/login" class="nm-portal-link">
        <i class="bi bi-person-badge"></i> Employee Portal Login
      </a>
    </div>

  </div>
</div>



<script>
document.addEventListener('DOMContentLoaded', () => {
  const toggleBtn = document.getElementById('togglePassword');
  const passwordInput = document.getElementById('password');
  if (toggleBtn && passwordInput) {
    toggleBtn.addEventListener('click', function () {
      const isPass = passwordInput.type === 'password';
      passwordInput.type = isPass ? 'text' : 'password';
      this.classList.toggle('bi-eye');
      this.classList.toggle('bi-eye-slash');
    });
  }
});
</script>
