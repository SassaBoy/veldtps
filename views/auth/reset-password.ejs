<%- include('../partials/header') %>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .nm-auth-bg {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #080f1a;
    background-image:
      radial-gradient(ellipse 70% 50% at 20% 55%, rgba(245,166,35,0.05) 0%, transparent 65%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(96,165,250,0.04) 0%, transparent 65%);
    padding: 120px 20px 80px;
  }

  .nm-auth-card {
    width: 100%;
    max-width: 440px;
    background: linear-gradient(145deg, #0d1b2a 0%, #0a1520 100%);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: 52px 40px 48px;
    box-shadow:
      0 32px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(255,255,255,0.03) inset,
      0 1px 0 rgba(255,255,255,0.07) inset;
    position: relative;
    animation: slideUp 0.4s cubic-bezier(0.22,1,0.36,1) both;
  }
  .nm-auth-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245,166,35,0.3), transparent);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active {
    -webkit-background-clip: text;
    -webkit-text-fill-color: #ffffff !important;
    transition: background-color 5000s ease-in-out 0s;
    box-shadow: inset 0 0 20px 20px #0e2035 !important;
  }

  /* ── Brand ────────────────────────────────────────────────────────────── */
  .nm-auth-brand { text-align: center; margin-bottom: 36px; }
  .nm-auth-brand-icon {
    width: 56px; height: 56px; border-radius: 16px;
    background: linear-gradient(135deg, #f5a623, #d4880a);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px;
    box-shadow: 0 6px 24px rgba(245,166,35,0.35), 0 0 0 1px rgba(245,166,35,0.2);
  }
  .nm-auth-brand-icon i { font-size: 1.5rem; color: #fff; }
  .nm-auth-title {
    font-family: 'Sora', 'DM Sans', sans-serif;
    font-size: 1.4rem; font-weight: 700;
    color: rgba(255,255,255,0.95); margin: 0 0 5px;
    letter-spacing: -0.01em;
  }
  .nm-auth-sub { font-size: 0.84rem; color: rgba(255,255,255,0.38); margin: 0; }

  /* ── Input groups ─────────────────────────────────────────────────────── */
  .nm-input-group { position: relative; margin-bottom: 20px; }
  .nm-input-group:last-of-type { margin-bottom: 0; }

  .nm-input-group .nm-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 1rem; color: rgba(255,255,255,0.32); z-index: 2; pointer-events: none;
  }

  .nm-input {
    display: block; width: 100%; padding: 12px 13px 12px 44px;
    background: #0e2035; border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px; color: rgba(255,255,255,0.92);
    font-family: 'DM Sans', sans-serif; font-size: 0.9rem;
    outline: none; transition: border-color 0.18s, box-shadow 0.18s;
  }
  .nm-input:focus { border-color: rgba(245,166,35,0.5); box-shadow: 0 0 0 3px rgba(245,166,35,0.09); }
  .nm-input::placeholder { color: rgba(255,255,255,0.2); }
  .nm-input.valid   { border-color: rgba(34,197,94,0.4); }
  .nm-input.invalid { border-color: rgba(248,113,113,0.45); }

  .nm-eye {
    position: absolute; right: 13px; top: 50%; transform: translateY(-50%);
    font-size: 1.1rem; color: rgba(255,255,255,0.38);
    cursor: pointer; z-index: 3; transition: color 0.15s;
  }
  .nm-eye:hover { color: rgba(255,255,255,0.7); }

  .nm-validation-msg { font-size: 0.75rem; margin-top: 5px; display: block; line-height: 1.4; }
  .nm-val-ok  { color: #22c55e; }
  .nm-val-err { color: #f87171; }

  /* ── Submit ───────────────────────────────────────────────────────────── */
  .nm-btn-submit {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; padding: 13px; border-radius: 10px;
    background: linear-gradient(135deg, #f5a623, #e8981e);
    color: #1a0e00; font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    border: none; cursor: pointer; margin-top: 28px;
    transition: opacity 0.16s, transform 0.12s, box-shadow 0.16s;
    box-shadow: 0 4px 18px rgba(245,166,35,0.25);
  }
  .nm-btn-submit:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 6px 24px rgba(245,166,35,0.35); }
  .nm-btn-submit:active { transform: translateY(0); }

  /* ── Back link ────────────────────────────────────────────────────────── */
  .nm-back-link {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    margin-top: 24px; font-size: 0.83rem;
    color: rgba(255,255,255,0.38); text-decoration: none;
    transition: color 0.15s;
  }
  .nm-back-link:hover { color: #f5a623; }

  /* ── Password strength bar ────────────────────────────────────────────── */
  .nm-strength-bar {
    display: flex; gap: 4px; margin-top: 7px;
  }
  .nm-strength-seg {
    flex: 1; height: 3px; border-radius: 3px;
    background: rgba(255,255,255,0.08);
    transition: background 0.3s;
  }
  .nm-strength-seg.weak   { background: #f87171; }
  .nm-strength-seg.fair   { background: #fbbf24; }
  .nm-strength-seg.good   { background: #22c55e; }
  .nm-strength-seg.strong { background: #22c55e; }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .nm-auth-bg { padding: 100px 16px 60px; align-items: flex-start; }
    .nm-auth-card { padding: 36px 24px 32px; border-radius: 16px; }
    .nm-auth-title { font-size: 1.25rem; }
  }
  @media (max-width: 360px) {
    .nm-auth-card { padding: 28px 18px 28px; }
  }
</style>

<div class="nm-auth-bg">
  <div class="nm-auth-card">

    <div class="nm-auth-brand">
      <div class="nm-auth-brand-icon"><i class="bi bi-key-fill"></i></div>
      <h1 class="nm-auth-title">Set New Password</h1>
      <p class="nm-auth-sub">Create a strong, secure password for your account</p>
    </div>

    <form action="/reset-password/<%= token %>" method="POST" id="resetForm" novalidate>

      <div class="nm-input-group">
        <i class="bi bi-lock nm-icon"></i>
        <input type="password" name="password" id="password"
          class="nm-input" placeholder="New password" required autocomplete="new-password" />
        <i class="bi bi-eye-slash nm-eye" id="togglePassword" role="button" aria-label="Show password"></i>
        <div class="nm-strength-bar" id="strengthBar">
          <div class="nm-strength-seg" id="seg1"></div>
          <div class="nm-strength-seg" id="seg2"></div>
          <div class="nm-strength-seg" id="seg3"></div>
          <div class="nm-strength-seg" id="seg4"></div>
        </div>
        <small id="passwordMsg" class="nm-validation-msg"></small>
      </div>

      <div class="nm-input-group">
        <i class="bi bi-shield-check nm-icon"></i>
        <input type="password" name="confirmPassword" id="confirmPassword"
          class="nm-input" placeholder="Confirm new password" required autocomplete="new-password" />
        <small id="confirmMsg" class="nm-validation-msg"></small>
      </div>

      <button type="submit" class="nm-btn-submit">
        <i class="bi bi-check2-circle"></i> Update Password
      </button>
    </form>

    <a href="/login" class="nm-back-link">
      <i class="bi bi-arrow-left"></i> Back to Login
    </a>

  </div>
</div>



<script>
document.addEventListener('DOMContentLoaded', () => {
  const pw    = document.getElementById('password');
  const cpw   = document.getElementById('confirmPassword');
  const pwMsg = document.getElementById('passwordMsg');
  const cpMsg = document.getElementById('confirmMsg');
  const segs  = [document.getElementById('seg1'), document.getElementById('seg2'),
                 document.getElementById('seg3'), document.getElementById('seg4')];

  // Eye toggle
  document.getElementById('togglePassword').addEventListener('click', function () {
    const isPass = pw.type === 'password';
    pw.type = isPass ? 'text' : 'password';
    this.classList.toggle('bi-eye');
    this.classList.toggle('bi-eye-slash');
  });

  function getStrength(v) {
    let score = 0;
    if (v.length >= 8)  score++;
    if (v.length >= 12) score++;
    if (/[A-Z]/.test(v) && /[a-z]/.test(v)) score++;
    if (/\d/.test(v) && /[^A-Za-z0-9]/.test(v)) score++;
    return score;
  }

  const labels = ['', 'Weak', 'Fair', 'Good', 'Strong'];
  const classes = ['', 'weak', 'fair', 'good', 'strong'];

  function validate() {
    const v = pw.value, c = cpw.value;

    // Strength bar
    segs.forEach(s => { s.className = 'nm-strength-seg'; });
    if (v.length > 0) {
      const str = getStrength(v);
      for (let i = 0; i < str; i++) segs[i].classList.add(classes[str]);
      const ok = v.length >= 8;
      pwMsg.textContent = ok ? `Strength: ${labels[str]}` : 'Minimum 8 characters required';
      pwMsg.className   = 'nm-validation-msg ' + (ok ? 'nm-val-ok' : 'nm-val-err');
      pw.classList.toggle('valid',   ok);
      pw.classList.toggle('invalid', !ok);
    } else {
      pwMsg.textContent = '';
      pw.classList.remove('valid', 'invalid');
    }

    if (c.length > 0) {
      const match = v === c;
      cpMsg.textContent = match ? '✓ Passwords match' : 'Passwords do not match';
      cpMsg.className   = 'nm-validation-msg ' + (match ? 'nm-val-ok' : 'nm-val-err');
      cpw.classList.toggle('valid',   match);
      cpw.classList.toggle('invalid', !match);
    } else {
      cpMsg.textContent = '';
      cpw.classList.remove('valid', 'invalid');
    }
  }

  pw.addEventListener('input', validate);
  cpw.addEventListener('input', validate);

  document.getElementById('resetForm').addEventListener('submit', e => {
    if (pw.value.length < 8 || pw.value !== cpw.value) {
      e.preventDefault();
      validate();
    }
  });
});
</script>
