                      <td class="group-sep">
                        <div class="nm-leave-cell">
                          <div class="nm-leave-row">
                            <span class="nm-leave-pip paid"></span>
                            <input type="number" name="employees[<%= emp._id %>][annualLeavePaid]"
                              data-key="ann-paid-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                              class="nm-input v-lpaid payroll-field" value="0" step="0.5" min="0" placeholder="0">
                          </div>
                          <div class="nm-bal">Bal: <strong><%= emp.annualLeaveBalance %>d</strong></div>
                        </div>
                      </td>

                      <td>
                        <div class="nm-leave-cell">
                          <div class="nm-leave-row">
                            <span class="nm-leave-pip unpd"></span>
                            <input type="number" name="employees[<%= emp._id %>][annualLeaveUnpaid]"
                              data-key="ann-unpd-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                              class="nm-input v-lunpd payroll-field" value="0" step="0.5" min="0" placeholder="0">
                          </div>
                        </div>
                      </td>

                      <td class="group-sep">
                        <div class="nm-leave-cell">
                          <div class="nm-leave-row">
                            <span class="nm-leave-pip paid"></span>
                            <input type="number" name="employees[<%= emp._id %>][sickLeavePaid]"
                              data-key="sick-paid-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                              class="nm-input v-lpaid payroll-field" value="0" step="0.5" min="0" placeholder="0">
                          </div>
                        </div>
                      </td>

                      <td>
                        <div class="nm-leave-cell">
                          <div class="nm-leave-row">
                            <span class="nm-leave-pip unpd"></span>
                            <input type="number" name="employees[<%= emp._id %>][sickLeaveUnpaid]"
                              data-key="sick-unpd-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                              class="nm-input v-lunpd payroll-field" value="0" step="0.5" min="0" placeholder="0">
                          </div>
                          <div class="nm-bal">Bal: <strong><%= emp.sickLeaveBalance %>d</strong></div>
                        </div>
                      </td>

                      <td>
                        <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);">
                          <%= emp.pensionFundName || '—' %>
                        </div>
                        <input type="number" name="employees[<%= emp._id %>][pensionContribution]"
                          class="nm-input payroll-field" value="<%= emp.pensionContribution || 0 %>" step="0.01" min="0"
                          style="margin-top:4px;">
                      </td>

                      <td>
                        <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);">
                          <%= emp.medicalAidFundName || '—' %>
                        </div>
                        <input type="number" name="employees[<%= emp._id %>][medicalAidContribution]"
                          class="nm-input payroll-field" value="<%= emp.medicalAidContribution || 0 %>" step="0.01" min="0"
                          style="margin-top:4px;">
                      </td>

                      <!-- New Fund Fields -->
                      <td>
                        <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);">
                          <%= emp.providentFundName || '—' %>
                        </div>
                        <input type="number" name="employees[<%= emp._id %>][providentFundContribution]"
                          class="nm-input payroll-field" value="<%= emp.providentFundContribution || 0 %>" step="0.01" min="0"
                          style="margin-top:4px;">
                      </td>

                      <td>
                        <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);">
                          <%= emp.retirementFundName || '—' %>
                        </div>
                        <input type="number" name="employees[<%= emp._id %>][retirementFundContribution]"
                          class="nm-input payroll-field" value="<%= emp.retirementFundContribution || 0 %>" step="0.01" min="0"
                          style="margin-top:4px;">
                      </td>

                      <td>
                        <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);">
                          <%= emp.studyPolicyName || '—' %>
                        </div>
                        <input type="number" name="employees[<%= emp._id %>][studyPolicyContribution]"
                          class="nm-input payroll-field" value="<%= emp.studyPolicyContribution || 0 %>" step="0.01" min="0"
                          style="margin-top:4px;">
                      </td>

                      <td>
                        <select name="employees[<%= emp._id %>][housingType]" class="nm-input payroll-field">
                          <option value="none"       <%= emp.housingType === 'none'       ? 'selected' : '' %>>None</option>
                          <option value="free"       <%= emp.housingType === 'free'       ? 'selected' : '' %>>Free Housing</option>
                          <option value="subsidised" <%= emp.housingType === 'subsidised' ? 'selected' : '' %>>Subsidised</option>
                        </select>
                      </td>

                      <td>
                        <label style="display:flex;align-items:center;gap:6px;font-size:0.8rem;color:rgba(255,255,255,0.7);">
                          <input type="checkbox" name="employees[<%= emp._id %>][hasCompanyVehicle]"
                            <%= emp.hasCompanyVehicle ? 'checked' : '' %> class="payroll-field">
                          Has Company Vehicle
                        </label>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <!-- ── Mobile cards ──────────────────────────────────────────────────── -->
            <div class="nm-mobile-cards-wrapper">
              <% employees.forEach(emp => { 
                const days = workingDaysInMonth || 22;
                const hrs = hoursPerDay || 8;
                const dailyRate  = Math.round((emp.basicSalary / days) * 100) / 100;
                const hourlyRate = Math.round((emp.basicSalary / (days * hrs)) * 100) / 100;
              %>
                <div class="nm-mobile-card" data-id-number="<%= emp.idNumber %>">

                  <div class="nm-mc-header">
