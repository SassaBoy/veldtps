                  </div>

                </div>
              <% }) %>
            </div>

            <!-- Legend (desktop only) -->
            <div class="nm-legend">
              <span class="nm-legend-lbl">Guide</span>
              <span class="nm-legend-item"><span class="nm-legend-dot" style="background:#34d399;"></span> Taxable earning / Paid Leave</span>
              <span class="nm-legend-item"><span class="nm-legend-dot" style="background:#60a5fa;"></span> Non-taxable earning</span>
              <span class="nm-legend-item"><span class="nm-legend-dot" style="background:#f87171;"></span> Deduction / Unpaid Leave</span>
              <span class="nm-legend-item" style="margin-left:auto;color:rgba(248,113,113,0.55);font-size:0.68rem;">
                <i class="bi bi-exclamation-triangle" style="font-size:0.65rem;"></i>
                Unpaid leave deducts N$(daily rate × days) from gross
              </span>
            </div>
          </div>

          <!-- Submit bar -->
          <div class="nm-submit-bar">
            <button type="submit" class="nm-btn-primary" id="runPayrollBtn" style="padding:10px 22px;">
              <i class="bi bi-play-circle-fill"></i> Process Payroll
            </button>
            <div class="nm-submit-info">
              <strong><%= employees.length %> employee<%= employees.length !== 1 ? 's' : '' %></strong>
              · <strong><%= months.find(m=>m.value===selectedMonth).name %> <%= selectedYear %></strong>
            </div>
            <button type="button" class="nm-btn-ghost ms-auto" onclick="clearDraft()" style="padding:9px 14px;">
              <i class="bi bi-arrow-counterclockwise"></i> Reset
            </button>
          </div>
        </form>

        <% } else { %>
        <div class="nm-panel">
          <div class="nm-empty">
            <i class="bi bi-people"></i>
            <p>No active employees found. <a href="/employees/new" style="color:var(--gold);">Add employees</a> to get started.</p>
          </div>
        </div>
        <% } %>

      </div>
    </div>

  </div>

  <!-- Safe Footer (no user variable) -->
  <footer class="nm-footer">
    <div class="nm-footer-inner">

      <!-- Left: brand + copyright -->
      <div class="nm-footer-left">
        <a href="/dashboard" class="nm-footer-brand">
          <span class="nm-footer-brand-icon"><i class="bi bi-coin"></i></span>
          <span class="nm-footer-brand-text">Veldt Payroll</span>
        </a>
        <span class="nm-footer-copy">
          &copy; <%= new Date().getFullYear() %> Veldt Payroll &mdash; Built for Namibian businesses
        </span>
      </div>

      <!-- Center: utility links -->
      <nav class="nm-footer-links" aria-label="Footer links">
        <a href="/privacy" class="nm-footer-link">Privacy</a>
        <a href="/terms" class="nm-footer-link">Terms</a>
        <a href="/support" class="nm-footer-link">Support</a>
        <a href="https://namra.org.na" target="_blank" rel="noopener" class="nm-footer-link">NamRA</a>
      </nav>

      <!-- Right: compliance notice -->
      <div class="nm-footer-notice" role="note">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Payroll calculations are for guidance only. Always verify with NamRA and Social Security before final submission.</span>
      </div>

    </div>
  </footer>
</div>

<script>
const CUSTOM_ITEMS = <%- JSON.stringify(customPayItems.map(i => ({
  id: i._id.toString(), name: i.name, type: i.type,
  inputMode: i.inputMode, defaultAmount: i.defaultAmount
}))) %>;
const HAS_CUSTOM  = CUSTOM_ITEMS.length > 0;
const STORAGE_KEY = 'payroll_draft_<%= selectedMonth %>_<%= selectedYear %>';

function downloadTemplate() {
  let headers = ['ID_Number'];
  if (HAS_CUSTOM) {
    CUSTOM_ITEMS.forEach(item => headers.push(item.name));
  } else {
    headers = headers.concat(['Taxable_Allow', 'NonTax_Allow', 'Deductions']);
  }
  headers = headers.concat(['Normal_OT','Public_Holiday_OT','Annual_Leave_Paid','Annual_Leave_Unpaid','Sick_Leave_Paid','Sick_Leave_Unpaid']);

  let csv = headers.join(',') + '\n';

  const sampleEmployees = [
    ['95010100453'],
    ['92050511234'],
    ['88031256789'],
    ['97082344567'],
    ['89121533456']
  ];

  sampleEmployees.forEach(baseRow => {
    let row = [...baseRow];
    if (HAS_CUSTOM) {
      CUSTOM_ITEMS.forEach(() => row.push('0'));
    } else {
      row = row.concat(['0', '0', '0']);
    }
    row = row.concat(['0', '0', '0', '0', '0', '0']);
    csv += row.join(',') + '\n';
  });

  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const link = document.createElement('a');
  const url = URL.createObjectURL(blob);
  link.href = url;
  link.download = `payroll_template_${<%= selectedMonth %>}_${<%= selectedYear %>}.csv`;
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
  URL.revokeObjectURL(url);
}

function handleCSV(input) {
  const reader = new FileReader();
  reader.onload = function () {
    const lines   = reader.result.trim().split('\n');
    const headers = lines[0].split(',').map(h => h.trim());
    if (!headers[0].toLowerCase().includes('id')) {
      showImportStatus('error', 'Invalid CSV: first column must be "ID_Number".');
      return;
    }
    let matched = 0, failed = 0;
    const stdMap = {
      'taxable_allow':'tax-','nontax_allow':'ntax-','deductions':'ded-',
      'normal_ot':'normal-ot-','public_holiday_ot':'pub-ot-',
      'annual_leave_paid':'ann-paid-','annual_leave_unpaid':'ann-unpd-',
      'sick_leave_paid':'sick-paid-','sick_leave_unpaid':'sick-unpd-'
    };
    lines.slice(1).forEach(line => {
      if (!line.trim()) return;
      const parts = line.split(',').map(p => p.trim());
      const idNum = parts[0];
      const hits  = document.querySelectorAll(`input[data-match="${idNum}"]`);
      if (!hits.length) { failed++; return; }
      matched++;
      headers.slice(1).forEach((header, colIdx) => {
        const val = parts[colIdx + 1] || '';
        if (HAS_CUSTOM) {
          const ci = CUSTOM_ITEMS.find(item => item.name.toLowerCase() === header.toLowerCase());
          if (ci) {
            const inp = document.querySelector(`input[data-match="${idNum}"][data-custom-id="${ci.id}"]`);
            if (inp) { inp.value = val; inp.dispatchEvent(new Event('input')); }
            return;
          }
        }
        const prefix = stdMap[header.toLowerCase().replace(/\s+/g,'_')];
        if (prefix) {
          document.querySelectorAll(`input[data-match="${idNum}"]`).forEach(el => {
            if (el.dataset.key && el.dataset.key.startsWith(prefix)) {
              el.value = val; el.dispatchEvent(new Event('input'));
            }
          });
        }
      });
    });
    const msg = failed > 0
      ? `Matched <strong>${matched}</strong> records — <strong>${failed}</strong> ID(s) not found.`
      : `<strong>${matched}</strong> records imported successfully.`;
    showImportStatus('info', msg);
  };
  reader.readAsText(input.files[0]);
}

function showImportStatus(type, html) {
  const el = document.getElementById('importStatusAlert');
  el.style.display = 'flex';
  el.style.borderColor = type === 'error' ? 'rgba(248,113,113,0.3)' : 'rgba(96,165,250,0.25)';
  el.style.color       = type === 'error' ? '#f87171' : 'rgba(96,165,250,0.85)';
  document.getElementById('importStatusText').innerHTML = html;
}

window.addEventListener('load', () => {
  const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
  if (saved) {
    Object.keys(saved).forEach(key => {
      const inp = document.querySelector(`[data-key="${key}"]`);
      if (inp) inp.value = saved[key];
    });
  }
  <% if (subscription && subscription.plan === 'trial' && employees.length > 3) { %>
    const btn = document.getElementById('runPayrollBtn');
    if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; btn.title = 'Upgrade to process more than 3 employees'; }
  <% } %>
});

let saveTimer;
document.querySelectorAll('.payroll-field').forEach(input => {
  input.addEventListener('input', e => {
    clearTimeout(saveTimer);
    document.getElementById('autosaveStatus').textContent = 'Saving…';
    saveTimer = setTimeout(() => {
      let draft = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      draft[e.target.dataset.key] = e.target.value;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(draft));
      document.getElementById('autosaveStatus').textContent = 'Saved';
    }, 600);
  });
});

document.getElementById('payrollForm')?.addEventListener('keydown', e => {
  if (e.key !== 'Enter') return;
  const active = document.activeElement;
  if (!active.classList.contains('payroll-field')) return;
  e.preventDefault();
  const currentTd  = active.closest('td');
  const currentRow = active.closest('tr');
  if (!currentTd || !currentRow) return;
  const colIdx  = Array.from(currentRow.children).indexOf(currentTd);
  const nextRow = currentRow.nextElementSibling;
  if (!nextRow) return;
  const targetTd = nextRow.children[colIdx];
  if (!targetTd) return;
  const inputs      = targetTd.querySelectorAll('input.payroll-field');
  const activeInputs = currentTd.querySelectorAll('input.payroll-field');
  const inputIdx    = Array.from(activeInputs).indexOf(active);
  const nextInput   = inputs[inputIdx] || inputs[0];
  if (nextInput) { nextInput.focus(); nextInput.select(); }
});

function clearDraft() {
  if (confirm('Clear all entered values and reload?')) {
    localStorage.removeItem(STORAGE_KEY);
    location.reload();
  }
}
</script>

<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- Custom JS -->
<script src="/js/main.js"></script>
</body>
</html>