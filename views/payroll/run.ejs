              <% months.forEach(m => { %>
                <option value="<%= m.value %>" <%= m.value === selectedMonth ? 'selected' : '' %>><%= m.name %></option>
              <% }) %>
            </select>
            <select name="year" class="nm-select">
              <% years.forEach(y => { %>
                <option value="<%= y %>" <%= y === selectedYear ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>
            <button type="submit" class="nm-btn-primary" style="padding:8px 14px;">
              <i class="bi bi-arrow-clockwise"></i> Load
            </button>
          </form>

          <div class="nm-toolbar-spacer"></div>

          <button type="button" onclick="downloadTemplate()" class="nm-btn-ghost">
            <i class="bi bi-download"></i> <span class="d-none d-sm-inline">CSV Template</span>
          </button>
          <button type="button" class="nm-btn-primary" onclick="document.getElementById('csvInput').click()">
            <i class="bi bi-file-earmark-spreadsheet"></i>
            <span class="d-none d-sm-inline">Import CSV</span>
          </button>
          <input type="file" id="csvInput" style="display:none;" accept=".csv" onchange="handleCSV(this)">
        </div>

        <!-- ── Notices ────────────────────────────────────────────────────────────── -->
        <% if (customPayItems.length > 0) { %>
          <div class="nm-notice custom">
            <i class="bi bi-sliders2-vertical"></i>
            <span>
              <strong><%= customPayItems.length %> custom item<%= customPayItems.length !== 1 ? 's' : '' %></strong> active.
              <a href="/settings#custom-items">Manage →</a>
            </span>
          </div>
        <% } else { %>
          <div class="nm-notice info" style="color:rgba(255,255,255,0.28);border-color:rgba(255,255,255,0.06);">
            <i class="bi bi-plus-circle" style="color:rgba(245,166,35,0.5);"></i>
            <span>Add custom earnings or deductions in <a href="/settings#custom-items" style="color:rgba(245,166,35,0.7);">Settings →</a></span>
          </div>
        <% } %>

        <!-- Import alert -->
        <div class="nm-import-alert" id="importStatusAlert">
          <i class="bi bi-info-circle-fill"></i>
          <span id="importStatusText"></span>
        </div>

        <!-- ── Payroll form ───────────────────────────────────────────────────────── -->
        <% if (employees.length > 0) { %>
        <form action="/payroll/run" method="POST" id="payrollForm">
          <input type="hidden" name="month" value="<%= selectedMonth %>" />
          <input type="hidden" name="year"  value="<%= selectedYear %>"  />

          <div class="nm-panel">
            <div class="nm-panel-header">
              <div class="nm-panel-title">
                <i class="bi bi-people-fill" style="color:var(--blue);"></i>
                Payroll Entry — <%= months.find(m=>m.value===selectedMonth).name %> <%= selectedYear %>
