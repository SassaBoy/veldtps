                    <th style="min-width:140px;">Provident Fund <span class="th-type">Contribution</span></th>
                    <th style="min-width:140px;">Retirement Fund <span class="th-type">Contribution</span></th>
                    <th style="min-width:140px;">Study Policy <span class="th-type">Contribution</span></th>

                    <th style="min-width:110px;">Housing <span class="th-type">Fringe</span></th>
                    <th style="min-width:110px;">Company Vehicle <span class="th-type">Fringe</span></th>
