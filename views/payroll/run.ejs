                      <%
                        const colCls = item.type === 'earning_taxable'    ? 'col-earn-tax'
                                     : item.type === 'earning_nontaxable' ? 'col-earn-ntax'
                                     : 'col-deduct';
                        const typeLbl = item.type === 'earning_taxable'    ? 'Taxable'
                                      : item.type === 'earning_nontaxable' ? 'Non-taxable'
                                      : 'Deduction';
                      %>
                      <th style="min-width:110px;" class="<%= colCls %>">
                        <%= item.name %>
                        <span class="th-type"><%= typeLbl %><%= item.inputMode === 'fixed' ? ' · Fixed' : '' %></span>
                      </th>
                    <% }) %>

                    <!-- UPDATED: Separate overtime columns -->
                    <th style="min-width:100px;">Normal OT <span class="th-type">@ 1.5×</span></th>
                    <th style="min-width:100px;">Public Holiday OT <span class="th-type">@ 2.0×</span></th>

                    <th style="min-width:130px;" class="col-leave-paid">Annual Leave Paid <span class="th-type">days</span></th>
                    <th style="min-width:130px;" class="col-leave-unp">Annual Leave Unpaid <span class="th-type">days</span></th>
                    <th style="min-width:130px;" class="col-leave-paid">Sick Leave Paid <span class="th-type">days</span></th>
                    <th style="min-width:130px;" class="col-leave-unp">Sick Leave Unpaid <span class="th-type">days</span></th>

                    <th style="min-width:140px;">Pension Fund <span class="th-type">Contribution</span></th>
                    <th style="min-width:140px;">Medical Aid <span class="th-type">Contribution</span></th>

