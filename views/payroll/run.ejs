                    <div class="nm-mc-field">
                      <label class="nm-mc-label">Pension Fund</label>
                      <div style="font-size:0.78rem;color:rgba(255,255,255,0.6);"><%= emp.pensionFundName || '—' %></div>
                      <input type="number" name="employees[<%= emp._id %>][pensionContribution]"
