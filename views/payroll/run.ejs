            <!-- ── Desktop table ─────────────────────────────────────────────────── -->
            <div class="table-responsive">
              <table class="nm-table" id="entryTable">
                <thead>
                  <tr>
                    <th style="min-width:160px;">Employee</th>
                    <th style="min-width:130px;">Basic Salary</th>

