                        <label class="nm-mc-label lpaid">Paid (days)</label>
                        <input type="number" name="employees[<%= emp._id %>][sickLeavePaid]"
                          data-key="sick-paid-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input v-lpaid payroll-field" value="0" step="0.5" min="0" placeholder="0">
                      </div>
                      <div class="nm-mc-field">
                        <label class="nm-mc-label lunpd">Unpaid (days)</label>
                        <input type="number" name="employees[<%= emp._id %>][sickLeaveUnpaid]"
                          data-key="sick-unpd-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input v-lunpd payroll-field" value="0" step="0.5" min="0" placeholder="0">
                      </div>
                      <div class="nm-mc-bal">Balance: <strong><%= emp.sickLeaveBalance %> days</strong></div>
                    </div>
                  </div>

                  <div class="nm-mc-divider"></div>

                  <!-- Funds Section - aligned properly -->
