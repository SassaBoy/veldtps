                        const inpCls   = item.type === 'earning_taxable'    ? 'v-earn'
                                       : item.type === 'earning_nontaxable' ? 'v-ntax' : 'v-deduct';
                        const lblCls   = item.type === 'earning_taxable'    ? 'earn'
                                       : item.type === 'earning_nontaxable' ? 'ntax'  : 'deduct';
                        const itemIdStr = item._id.toString();
                        const draftKey  = `custom-${emp._id}-${itemIdStr}`;
                      %>
                        <div class="nm-mc-field">
                          <label class="nm-mc-label <%= lblCls %>"><%= item.name %></label>
                          <input type="number"
                            name="employees[<%= emp._id %>][custom][<%= itemIdStr %>]"
                            data-key="<%= draftKey %>" data-match="<%= emp.idNumber %>"
                            data-custom-id="<%= itemIdStr %>"
                            class="nm-input <%= inpCls %> payroll-field"
                            value="<%= item.inputMode === 'fixed' ? item.defaultAmount : 0 %>"
                            step="0.01" min="0"
                            placeholder="<%= item.inputMode === 'fixed' ? item.defaultAmount : '0.00' %>">
