                        <label class="nm-mc-label ot">Normal OT (1.5×)</label>
                        <input type="number" name="employees[<%= emp._id %>][normalOvertimeHours]"
                          data-key="normal-ot-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input payroll-field" value="0" step="0.01" min="0" placeholder="Hours">
                        <p class="nm-hint" style="font-size: 0.7rem;">Paid at 1.5× hourly rate</p>
                      </div>
                      <div>
                        <label class="nm-mc-label ot">Public Holiday OT (2.0×)</label>
                        <input type="number" name="employees[<%= emp._id %>][publicHolidayOvertimeHours]"
                          data-key="pub-ot-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input payroll-field" value="0" step="0.01" min="0" placeholder="Hours">
                        <p class="nm-hint" style="font-size: 0.7rem;">Paid at 2.0× hourly rate</p>
                      </div>
                    </div>
                  </div>

                  <div class="nm-mc-divider"></div>

                  <div>
                    <div class="nm-mc-section-title">Annual Leave</div>
                    <div class="nm-mc-leave-group">
                      <div class="nm-mc-field">
                        <label class="nm-mc-label lpaid">Paid (days)</label>
                        <input type="number" name="employees[<%= emp._id %>][annualLeavePaid]"
                          data-key="ann-paid-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input v-lpaid payroll-field" value="0" step="0.5" min="0" placeholder="0">
                      </div>
                      <div class="nm-mc-field">
                        <label class="nm-mc-label lunpd">Unpaid (days)</label>
                        <input type="number" name="employees[<%= emp._id %>][annualLeaveUnpaid]"
                          data-key="ann-unpd-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input v-lunpd payroll-field" value="0" step="0.5" min="0" placeholder="0">
                      </div>
                      <div class="nm-mc-bal">Balance: <strong><%= emp.annualLeaveBalance %> days</strong></div>
                    </div>
                  </div>

                  <div>
