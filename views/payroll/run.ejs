                      <td>
                        <div class="nm-emp-name"><%= emp.fullName %></div>
                        <div class="nm-emp-id"><%= emp.idNumber %></div>
                      </td>
                      <td>
                        <div class="nm-salary">N$&nbsp;<%= emp.basicSalary.toLocaleString('en-NA',{minimumFractionDigits:2}) %></div>
                        <div class="nm-rates">
                          N$<%= dailyRate.toLocaleString('en-NA',{minimumFractionDigits:2}) %>/day<br>
                          N$<%= hourlyRate.toLocaleString('en-NA',{minimumFractionDigits:2}) %>/hr
                        </div>
                      </td>

                      <% customPayItems.forEach(item => {
                        const inpCls   = item.type === 'earning_taxable'    ? 'v-earn'
                                       : item.type === 'earning_nontaxable' ? 'v-ntax'
                                       : 'v-deduct';
                        const itemIdStr = item._id.toString();
                        const draftKey  = `custom-${emp._id}-${itemIdStr}`;
                      %>
                        <td>
                          <input type="number"
                            name="employees[<%= emp._id %>][custom][<%= itemIdStr %>]"
                            data-key="<%= draftKey %>" data-match="<%= emp.idNumber %>"
                            data-custom-id="<%= itemIdStr %>"
                            class="nm-input <%= inpCls %> payroll-field"
                            value="<%= item.inputMode === 'fixed' ? item.defaultAmount : 0 %>"
                            step="0.01" min="0"
                            placeholder="<%= item.inputMode === 'fixed' ? item.defaultAmount : '0.00' %>">
                          <% if (item.inputMode === 'fixed') { %>
                            <div style="font-size:0.6rem;color:var(--text-dim);margin-top:3px;">
                              Fixed: N$<%= item.defaultAmount.toLocaleString('en-NA',{minimumFractionDigits:2}) %>
                            </div>
                          <% } %>
                        </td>
                      <% }) %>

                      <!-- UPDATED: Separate overtime inputs (quick view) -->
                      <td>
                        <input type="number" name="employees[<%= emp._id %>][normalOvertimeHours]"
                          data-key="normal-ot-<%= emp._id %>" data-match="<%= emp.idNumber %>"
                          class="nm-input payroll-field" value="0" step="0.01" min="0" placeholder="Normal OT">
                      </td>
                      <td>
                        <input type="number" name="employees[<%= emp._id %>][publicHolidayOvertimeHours]"
                          data-key="pub-ot-<%= emp._id %>" data-match="<%= emp.idNumber %>"
