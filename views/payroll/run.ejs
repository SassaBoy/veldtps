              <span class="nm-page-meta-chip">
                <i class="bi bi-calendar3"></i>
                <%= months.find(m=>m.value===selectedMonth).name %> <%= selectedYear %>
              </span>
              <span class="nm-page-meta-chip">
                <i class="bi bi-people"></i>
                <%= employees.length %> employee<%= employees.length !== 1 ? 's' : '' %>
              </span>
              <% if (customPayItems.length > 0) { %>
                <span class="nm-page-meta-chip custom">
                  <i class="bi bi-sliders2-vertical"></i>
                  <%= customPayItems.length %> custom item<%= customPayItems.length !== 1 ? 's' : '' %>
                </span>
              <% } %>
            </div>
          </div>
        </div>

        <!-- ── Toolbar ────────────────────────────────────────────────────────────── -->
        <div class="nm-toolbar">
