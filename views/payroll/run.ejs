                      <div class="nm-mc-name"><%= emp.fullName %></div>
                      <div class="nm-mc-id"><%= emp.idNumber %></div>
                    </div>
                    <div>
                      <div class="nm-mc-salary">N$&nbsp;<%= emp.basicSalary.toLocaleString('en-NA',{minimumFractionDigits:2}) %></div>
                      <div class="nm-mc-rates">N$<%= dailyRate.toLocaleString('en-NA',{minimumFractionDigits:2}) %>/day · N$<%= hourlyRate.toLocaleString('en-NA',{minimumFractionDigits:2}) %>/hr</div>
                    </div>
