<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
  .nm-page-wrapper { flex:1; padding:32px 24px 48px; }
  .nm-page-inner   { max-width:1280px; margin:0 auto; }

  .nm-alert { display:flex; align-items:flex-start; gap:10px; padding:12px 16px; border-radius:10px; font-size:0.875rem; font-weight:500; margin-bottom:24px; }
  .nm-alert i { font-size:1rem; flex-shrink:0; margin-top:1px; }
  .nm-alert-success { background:rgba(46,204,138,0.1); border:1px solid rgba(46,204,138,0.25); color:#2ecc8a; }

  .nm-page-header { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:28px; flex-wrap:wrap; }
  .nm-page-title    { font-family:'Sora',sans-serif; font-size:1.5rem; font-weight:700; color:rgba(255,255,255,0.92); margin:0; letter-spacing:-0.02em; }
  .nm-page-subtitle { font-size:0.875rem; color:rgba(255,255,255,0.4); margin:5px 0 0; }

  .nm-btn-primary { display:inline-flex; align-items:center; gap:8px; padding:9px 20px; border-radius:9px; background:#f5a623; color:#1a0e00; font-family:'DM Sans',sans-serif; font-size:0.875rem; font-weight:600; border:none; cursor:pointer; text-decoration:none; white-space:nowrap; transition:background 0.16s,box-shadow 0.16s,transform 0.1s; }
  .nm-btn-primary:hover { background:#e8981e; color:#1a0e00; box-shadow:0 4px 16px rgba(245,166,35,0.25); transform:translateY(-1px); }

  .nm-panel { background:#0d1b2a; border:1px solid rgba(255,255,255,0.07); border-radius:14px; overflow:hidden; }

  .nm-table { width:100%; border-collapse:collapse; font-size:0.865rem; }
  .nm-table thead tr { border-bottom:1px solid rgba(255,255,255,0.07); }
  .nm-table thead th { padding:13px 16px; font-size:0.72rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; color:rgba(255,255,255,0.35); white-space:nowrap; background:#112235; }
  .nm-table tbody tr { border-bottom:1px solid rgba(255,255,255,0.04); transition:background 0.14s; }
  .nm-table tbody tr:last-child { border-bottom:none; }
  .nm-table tbody tr:hover { background:rgba(255,255,255,0.025); }
  .nm-table td { padding:15px 16px; vertical-align:middle; color:rgba(255,255,255,0.65); }

  .nm-period { font-family:'Sora',sans-serif; font-weight:700; font-size:0.9rem; color:rgba(255,255,255,0.92); }
  .nm-emp-pill { display:inline-flex; align-items:center; gap:5px; font-size:0.8rem; color:rgba(255,255,255,0.5); }
  .nm-money { font-family:'Sora',sans-serif; font-weight:600; white-space:nowrap; }
  .nm-money.green  { color:#2ecc8a; }
  .nm-money.red    { color:#f87171; }
  .nm-money.plain  { color:rgba(255,255,255,0.88); }
  .nm-date { font-size:0.8rem; color:rgba(255,255,255,0.35); }

  .nm-actions { display:flex; align-items:center; gap:6px; }
  .nm-action-btn { width:32px; height:32px; border-radius:7px; display:flex; align-items:center; justify-content:center; font-size:0.82rem; text-decoration:none; border:1px solid rgba(255,255,255,0.07); background:transparent; cursor:pointer; transition:background 0.14s,border-color 0.14s,color 0.14s; }
  .nm-action-btn.view { color:#60a5fa; }
  .nm-action-btn.view:hover { background:rgba(96,165,250,0.1); border-color:rgba(96,165,250,0.25); color:#60a5fa; }
  .nm-action-btn.zip  { color:rgba(255,255,255,0.5); }
  .nm-action-btn.zip:hover  { background:rgba(255,255,255,0.05); border-color:rgba(255,255,255,0.15); color:rgba(255,255,255,0.88); }
  .nm-action-btn.pdf  { color:#f87171; }
  .nm-action-btn.pdf:hover  { background:rgba(248,113,113,0.1); border-color:rgba(248,113,113,0.25); color:#f87171; }

  .nm-empty { text-align:center; padding:64px 24px; color:rgba(255,255,255,0.3); }
  .nm-empty i { font-size:2.5rem; display:block; margin-bottom:16px; opacity:0.3; }
  .nm-empty p { font-size:0.9rem; margin-bottom:18px; }
  .nm-empty a { color:#f5a623; text-decoration:none; font-weight:500; }
  .nm-empty a:hover { text-decoration:underline; }

  .nm-disclaimer { display:flex; align-items:flex-start; gap:10px; background:rgba(245,166,35,0.06); border:1px solid rgba(245,166,35,0.16); border-radius:10px; padding:12px 18px; margin-top:24px; font-size:0.815rem; color:rgba(245,166,35,0.8); line-height:1.5; }
  .nm-disclaimer i { color:#f5a623; flex-shrink:0; margin-top:1px; }

  @media (max-width:767.98px) {
    .nm-page-wrapper { padding:20px 16px 40px; }
    .nm-page-header  { flex-direction:column; align-items:flex-start; }
    .nm-table thead th:nth-child(3),
    .nm-table thead th:nth-child(6),
    .nm-table td:nth-child(3),
    .nm-table td:nth-child(6) { display:none; }
  }
</style>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <% if (success && success.length > 0) { %>
      <div class="nm-alert nm-alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span><%= success[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="nm-page-header">
      <div>
        <h1 class="nm-page-title">Payroll History</h1>
        <p class="nm-page-subtitle"><%= payrolls.length %> payroll run(s)</p>
      </div>
      <a href="/payroll/run" class="nm-btn-primary">
        <i class="bi bi-play-circle me-1"></i>Run Payroll
      </a>
    </div>

    <% if (payrolls.length === 0) { %>
      <div class="nm-panel">
        <div class="nm-empty">
          <i class="bi bi-receipt"></i>
          <p>No payroll runs yet.</p>
          <a href="/payroll/run">Run your first payroll &rarr;</a>
        </div>
      </div>
    <% } else { %>
      <div class="nm-panel">
        <div class="table-responsive">
          <table class="nm-table">
            <thead>
              <tr>
                <th>Period</th>
                <th>Employees</th>
                <th>Total Gross</th>
                <th>Total Net</th>
                <th>Total PAYE</th>
                <th>Employer Cost</th>
                <th>Processed</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% payrolls.forEach(run => { %>
                <tr>
                  <td><span class="nm-period"><%= moment(`${run.year}-${String(run.month).padStart(2,'0')}-01`).format('MMMM YYYY') %></span></td>
                  <td><span class="nm-emp-pill"><i class="bi bi-people"></i><%= run.employeeCount %></span></td>
                  <td><span class="nm-money plain">N$ <%= run.totalGrossPay.toLocaleString('en-NA', {minimumFractionDigits:2}) %></span></td>
                  <td><span class="nm-money green">N$ <%= run.totalNetPay.toLocaleString('en-NA', {minimumFractionDigits:2}) %></span></td>
                  <td><span class="nm-money red">N$ <%= run.totalPAYE.toLocaleString('en-NA', {minimumFractionDigits:2}) %></span></td>
                  <td><span class="nm-money plain">N$ <%= run.totalEmployerCost.toLocaleString('en-NA', {minimumFractionDigits:2}) %></span></td>
                  <td><span class="nm-date"><%= moment(run.processedAt).format('DD MMM YYYY') %></span></td>
                  <td>
                    <div class="nm-actions">
                      <a href="/payroll/<%= run._id %>" class="nm-action-btn view" title="View"><i class="bi bi-eye"></i></a>
                      <a href="/payroll/<%= run._id %>/zip" class="nm-action-btn zip" title="Download all payslips"><i class="bi bi-file-zip"></i></a>
                      <a href="/payroll/<%= run._id %>/compliance-pdf" class="nm-action-btn pdf" title="Compliance PDF"><i class="bi bi-file-earmark-pdf"></i></a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

    <div class="nm-disclaimer mt-4">
      <i class="bi bi-exclamation-triangle-fill"></i>
      <strong>Disclaimer:</strong> Payroll calculations are for guidance only. Always verify with NamRA and Social Security before final submission.
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
