<%- include('partials/header') %>
<%- include('partials/navbar') %>

<style>
  .nm-page-wrapper { flex:1; padding:40px 24px 72px; }
  .nm-page-inner   { max-width:900px; margin:0 auto; }

  .nm-support-header { text-align:center; margin-bottom:48px; }
  .nm-support-eyebrow { font-size:0.7rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; color:#f5a623; margin-bottom:12px; }
  .nm-support-title   { font-family:'Sora',sans-serif; font-size:1.9rem; font-weight:800; color:#fff; letter-spacing:-0.03em; margin:0 0 10px; }
  .nm-support-sub     { font-size:0.9rem; color:rgba(255,255,255,0.38); max-width:500px; margin:0 auto; line-height:1.6; }

  /* ── Contact cards ── */
  .nm-contact-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:44px; }
  @media (max-width:768px) { .nm-contact-grid { grid-template-columns:1fr; } }

  .nm-contact-card {
    background:#0d1b2a; border:1px solid rgba(255,255,255,0.07);
    border-radius:14px; padding:24px; text-align:center;
    transition:transform 0.18s, box-shadow 0.18s;
  }
  .nm-contact-card:hover { transform:translateY(-2px); box-shadow:0 10px 30px rgba(0,0,0,0.3); }
  .nm-contact-icon {
    width:48px; height:48px; border-radius:12px; margin:0 auto 16px;
    display:flex; align-items:center; justify-content:center; font-size:1.3rem;
  }
  .nm-contact-icon.email  { background:rgba(245,166,35,0.1); color:#f5a623; border:1px solid rgba(245,166,35,0.18); }
  .nm-contact-icon.phone  { background:rgba(46,204,138,0.1); color:#2ecc8a; border:1px solid rgba(46,204,138,0.18); }
  .nm-contact-icon.hours  { background:rgba(96,165,250,0.1); color:#60a5fa; border:1px solid rgba(96,165,250,0.18); }
  .nm-contact-label { font-family:'Sora',sans-serif; font-size:0.82rem; font-weight:700; color:rgba(255,255,255,0.8); margin-bottom:6px; }
  .nm-contact-value { font-size:0.875rem; color:rgba(255,255,255,0.45); line-height:1.5; }
  .nm-contact-value a { color:#f5a623; text-decoration:none; font-weight:600; }
  .nm-contact-value a:hover { text-decoration:underline; }

  /* ── FAQ section ── */
  .nm-section-label { font-family:'Sora',sans-serif; font-size:0.67rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(255,255,255,0.25); margin:0 0 14px 2px; }

  .nm-faq-panel { background:#0d1b2a; border:1px solid rgba(255,255,255,0.07); border-radius:14px; overflow:hidden; margin-bottom:24px; }

  details.nm-faq-item { border-bottom:1px solid rgba(255,255,255,0.05); }
  details.nm-faq-item:last-child { border-bottom:none; }
  details.nm-faq-item summary {
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 24px; cursor:pointer; list-style:none;
    font-family:'Sora',sans-serif; font-size:0.875rem; font-weight:600;
    color:rgba(255,255,255,0.82); transition:background 0.14s;
    user-select:none;
  }
  details.nm-faq-item summary:hover { background:rgba(255,255,255,0.02); }
  details.nm-faq-item summary::-webkit-details-marker { display:none; }
  details.nm-faq-item summary .faq-icon { font-size:0.82rem; color:rgba(255,255,255,0.3); transition:transform 0.2s; flex-shrink:0; margin-left:16px; }
  details.nm-faq-item[open] summary .faq-icon { transform:rotate(45deg); color:#f5a623; }
  details.nm-faq-item[open] summary { color:#fff; }

  .nm-faq-answer {
    padding:0 24px 20px;
    font-size:0.865rem; color:rgba(255,255,255,0.45); line-height:1.75;
  }
  .nm-faq-answer p { margin:0 0 8px; }
  .nm-faq-answer p:last-child { margin-bottom:0; }
  .nm-faq-answer a { color:#f5a623; text-decoration:none; }

  /* ── Response time banner ── */
  .nm-response-banner {
    display:flex; align-items:center; gap:14px;
    background:#0d1b2a; border:1px solid rgba(46,204,138,0.2);
    border-radius:12px; padding:16px 22px; margin-bottom:36px;
    font-size:0.855rem; color:rgba(255,255,255,0.5);
  }
  .nm-response-banner i { font-size:1.2rem; color:#2ecc8a; flex-shrink:0; }
  .nm-response-banner strong { color:rgba(255,255,255,0.75); }
</style>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <div class="nm-support-header">
