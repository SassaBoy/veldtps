<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<style>
  .nm-page-wrapper { flex: 1; padding: 32px 24px 48px; }
  .nm-page-inner { max-width: 1280px; margin: 0 auto; }

  .nm-page-header {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 16px;
    margin-bottom: 28px; flex-wrap: wrap;
  }
  .nm-page-title {
    font-family: 'Sora', sans-serif; font-size: 1.5rem;
    font-weight: 700; color: rgba(255,255,255,0.92);
    margin: 0; letter-spacing: -0.02em;
  }
  .nm-page-subtitle { font-size: 0.875rem; color: rgba(255,255,255,0.4); margin: 4px 0 0; }

  .nm-btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 20px; border-radius: 9px; background: #f5a623;
    color: #1a0e00; font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem; font-weight: 600; border: none;
    cursor: pointer; text-decoration: none; white-space: nowrap;
    transition: background 0.16s, box-shadow 0.16s, transform 0.1s;
  }
  .nm-btn-primary:hover {
    background: #e8981e; color: #1a0e00;
    box-shadow: 0 4px 16px rgba(245,166,35,0.25); transform: translateY(-1px);
  }
  .nm-btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 18px; border-radius: 9px; background: transparent;
    border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.65);
    font-size: 0.875rem; font-weight: 500; text-decoration: none;
    transition: background 0.16s, color 0.16s;
  }
  .nm-btn-ghost:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.92); }

  .nm-alert {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 16px; border-radius: 10px;
    font-size: 0.875rem; font-weight: 500; margin-bottom: 24px;
  }
  .nm-alert i { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
  .nm-alert-success { background: rgba(46,204,138,0.1); border: 1px solid rgba(46,204,138,0.25); color: #2ecc8a; }
  .nm-alert-danger  { background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.22); color: #f87171; }

  .nm-search-form { margin-bottom: 24px; }
  .nm-search-wrap {
    display: flex; align-items: center; gap: 8px;
    background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px; padding: 6px 6px 6px 14px;
    transition: border-color 0.16s, box-shadow 0.16s;
  }
  .nm-search-wrap:focus-within {
    border-color: rgba(245,166,35,0.4); box-shadow: 0 0 0 3px rgba(245,166,35,0.08);
  }
  .nm-search-icon { color: rgba(255,255,255,0.4); font-size: 0.9rem; flex-shrink: 0; }
  .nm-search-input {
    flex: 1; background: transparent; border: none; outline: none;
    color: rgba(255,255,255,0.92); font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem; padding: 4px 0; min-width: 0;
  }
  .nm-search-input::placeholder { color: rgba(255,255,255,0.35); }

  .nm-card { background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; overflow: hidden; }

  .nm-table { width: 100%; border-collapse: collapse; font-size: 0.865rem; margin: 0; }
  .nm-table thead tr { border-bottom: 1px solid rgba(255,255,255,0.07); }
  .nm-table thead th {
    padding: 13px 16px; font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    color: rgba(255,255,255,0.4); white-space: nowrap; background: #112235;
  }
  .nm-table tbody tr { border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.14s; }
  .nm-table tbody tr:last-child { border-bottom: none; }
  .nm-table tbody tr:hover { background: rgba(255,255,255,0.025); }
  .nm-table td { padding: 14px 16px; vertical-align: middle; color: rgba(255,255,255,0.65); }

  .nm-emp-cell { display: flex; align-items: center; gap: 11px; }
  .nm-emp-avatar {
    width: 34px; height: 34px; border-radius: 9px;
    background: linear-gradient(135deg, #2563eb, #60a5fa);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Sora', sans-serif; font-size: 0.8rem; font-weight: 700;
    color: #fff; flex-shrink: 0;
  }
  .nm-emp-name  { font-weight: 600; color: rgba(255,255,255,0.92); font-size: 0.875rem; }
  .nm-emp-email { font-size: 0.775rem; color: rgba(255,255,255,0.4); margin-top: 1px; }
  .nm-cell-main { color: rgba(255,255,255,0.65); font-weight: 500; }
  .nm-cell-sub  { font-size: 0.775rem; color: rgba(255,255,255,0.4); margin-top: 1px; }
  .nm-salary    { font-family: 'Sora', sans-serif; font-weight: 600; font-size: 0.875rem; color: rgba(255,255,255,0.92); white-space: nowrap; }

  .nm-badge { display: inline-flex; align-items: center; gap: 5px; font-size: 0.73rem; font-weight: 600; border-radius: 20px; padding: 3px 10px; white-space: nowrap; }
  .nm-badge-annual { background: rgba(245,166,35,0.1);  border: 1px solid rgba(245,166,35,0.2);  color: #f5a623; }
  .nm-badge-sick   { background: rgba(96,165,250,0.1);  border: 1px solid rgba(96,165,250,0.2);  color: #60a5fa; }
  .nm-badge-on     { background: rgba(46,204,138,0.1);  border: 1px solid rgba(46,204,138,0.2);  color: #2ecc8a; }
  .nm-badge-off    { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); color: rgba(255,255,255,0.4); }

  .nm-actions { display: flex; align-items: center; gap: 6px; }
  .nm-action-btn {
    width: 32px; height: 32px; border-radius: 7px;
    border: 1px solid rgba(255,255,255,0.07); background: transparent;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.82rem; cursor: pointer; text-decoration: none;
    transition: background 0.14s, border-color 0.14s, color 0.14s;
  }
  .nm-action-edit   { color: #60a5fa; }
  .nm-action-edit:hover   { background: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.25); color: #60a5fa; }
  .nm-action-delete { color: #f87171; }
  .nm-action-delete:hover { background: rgba(248,113,113,0.1); border-color: rgba(248,113,113,0.25); color: #f87171; }

  .nm-empty-state { background: #0d1b2a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; padding: 64px 24px; text-align: center; }
  .nm-empty-icon  { font-size: 2.5rem; color: rgba(255,255,255,0.4); margin-bottom: 16px; opacity: 0.4; }
  .nm-empty-text  { font-size: 0.9rem; color: rgba(255,255,255,0.4); margin-bottom: 20px; }

  @media (max-width: 767.98px) {
    .nm-page-wrapper { padding: 20px 16px 40px; }
    .nm-page-header  { flex-direction: column; align-items: flex-start; }
    .nm-page-title   { font-size: 1.25rem; }
    .nm-search-wrap  { flex-wrap: wrap; }
    .nm-search-input { min-width: 100%; order: 2; }
    .nm-search-icon  { display: none; }
    .nm-btn-primary.nm-search-btn { order: 3; width: 100%; justify-content: center; }
    .nm-table thead th:nth-child(4),
    .nm-table thead th:nth-child(5),
    .nm-table td:nth-child(4),
    .nm-table td:nth-child(5) { display: none; }
  }
</style>

<div class="nm-page-wrapper">
  <div class="nm-page-inner">

    <!-- Flash messages -->
    <% if (success && success.length > 0) { %>
      <div class="nm-alert nm-alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span><%= success[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="nm-alert nm-alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle-fill"></i>
        <span><%= error[0] %></span>
        <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <!-- Page header -->
    <div class="nm-page-header">
      <div>
        <h1 class="nm-page-title">Employees</h1>
        <p class="nm-page-subtitle"><%= employees.length %> active employee<%= employees.length !== 1 ? 's' : '' %></p>
      </div>
      <a href="/employees/new" class="nm-btn-primary">
        <i class="bi bi-person-plus"></i>Add Employee
      </a>
    </div>

    <!-- Search -->
    <form method="GET" action="/employees" class="nm-search-form">
      <div class="nm-search-wrap">
        <i class="bi bi-search nm-search-icon"></i>
        <input type="text" name="search" class="nm-search-input"
               placeholder="Search by name, position, department or email…"
               value="<%= search || '' %>" autocomplete="off" />
        <button type="submit" class="nm-btn-primary nm-search-btn">Search</button>
        <% if (search) { %>
          <a href="/employees" class="nm-btn-ghost">Clear</a>
        <% } %>
      </div>
    </form>

    <!-- Empty state -->
    <% if (employees.length === 0) { %>
      <div class="nm-empty-state">
        <div class="nm-empty-icon"><i class="bi bi-people"></i></div>
        <% if (search) { %>
          <p class="nm-empty-text">No employees found for <strong>"<%= search %>"</strong>.</p>
          <a href="/employees" class="nm-btn-ghost">Clear search</a>
        <% } else { %>
          <p class="nm-empty-text">No employees yet.</p>
          <a href="/employees/new" class="nm-btn-primary">Add your first employee</a>
        <% } %>
      </div>

    <% } else { %>
      <div class="nm-card">
        <div class="table-responsive">
          <table class="nm-table">
            <thead>
              <tr>
                <th>Employee</th>
                <th>Position / Dept</th>
                <th>Basic Salary</th>
                <th>Annual Leave</th>
                <th>Sick Leave</th>
                <th>Portal</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% employees.forEach(emp => { %>
                <tr>
                  <td>
                    <div class="nm-emp-cell">
                      <span class="nm-emp-avatar"><%= emp.fullName.charAt(0).toUpperCase() %></span>
                      <div>
                        <div class="nm-emp-name"><%= emp.fullName %></div>
                        <div class="nm-emp-email"><%= emp.email %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <div class="nm-cell-main"><%= emp.position || '—' %></div>
                    <div class="nm-cell-sub"><%= emp.department || '' %></div>
                  </td>
                  <td>
                    <span class="nm-salary">N$ <%= emp.basicSalary.toLocaleString('en-NA', {minimumFractionDigits:2}) %></span>
                  </td>
                  <td>
                    <span class="nm-badge nm-badge-annual"><i class="bi bi-sun"></i><%= emp.annualLeaveBalance %> days</span>
                  </td>
                  <td>
                    <span class="nm-badge nm-badge-sick"><i class="bi bi-heart-pulse"></i><%= emp.sickLeaveBalance %> days</span>
                  </td>
                  <td>
                    <% if (emp.portalEnabled) { %>
                      <span class="nm-badge nm-badge-on"><i class="bi bi-check-circle-fill"></i>On</span>
                    <% } else { %>
                      <span class="nm-badge nm-badge-off">Off</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="nm-actions">
                      <a href="/employees/<%= emp._id %>/edit" class="nm-action-btn nm-action-edit" title="Edit">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form action="/employees/<%= emp._id %>?_method=DELETE" method="POST" class="d-inline"
                            onsubmit="return confirm('Remove <%= emp.fullName %>? This cannot be undone.')">
                        <button type="submit" class="nm-action-btn nm-action-delete" title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    <% } %>

  </div>
</div>

<%- include('../partials/footer') %>
